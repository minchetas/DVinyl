<%- include('partials/header') %>

<script src="https://unpkg.com/html5-qrcode" type="text/javascript"></script>

<div class="max-w-screen-lg mx-auto pb-20 px-4">
    
    <div class="text-center mb-8 md:mb-10 pt-6">
        <h1 class="text-2xl md:text-3xl font-bold transition-colors">
            <%= t('add_dvd.title') %>
        </h1>
        <p class="text-sm md:text-base opacity-60 transition-colors">
            <%= t('add_dvd.desc') %>
        </p>
    </div>

    <div class="card-theme p-4 md:p-8 rounded-2xl shadow-xl mb-10 transition-colors">
        
        <form action="/search-dvds" method="POST" class="mb-6">
            <div class="flex flex-col md:flex-row gap-3">
                <div class="relative flex-grow">
                    <div class="absolute inset-y-0 left-0 flex items-center pl-4 pointer-events-none">
                        <i class="fa-solid fa-search opacity-50"></i>
                    </div>
                    <input type="text" name="query" value="<%= locals.scanned_barcode || '' %>" class="block w-full p-4 pl-12 border border-transparent rounded-xl bg-black/5 dark:bg-white/5 focus:ring-2 focus:ring-primary-theme focus:bg-transparent placeholder-opacity-50 text-base transition-all" placeholder="<%= t('add_dvd.search_placeholder') || 'Titre, Réalisateur ou Code-barres...' %>" required>
                </div>
                
                <button type="submit" class="w-full md:w-auto px-8 py-4 bg-primary-theme text-white font-bold rounded-xl hover:brightness-110 transition-all shadow-lg active:scale-95 duration-100">
                    <%= t('common.search') %>
                </button>
            </div>
        </form>

        <div class="relative flex py-4 items-center">
            <div class="flex-grow border-t border-black/10 dark:border-white/10 transition-colors"></div>
            <span class="flex-shrink-0 mx-4 opacity-50 text-xs font-bold uppercase tracking-widest transition-colors">
                <%= t('add_dvd.separator_or') %>
            </span>
            <div class="flex-grow border-t border-black/10 dark:border-white/10 transition-colors"></div>
        </div>

        <div class="mt-2">
            <button id="start-scan" type="button" class="w-full py-4 text-base font-bold bg-black/5 dark:bg-white/5 border border-transparent rounded-xl hover:bg-black/10 dark:hover:bg-white/10 focus:ring-4 focus:ring-primary-theme/30 transition-all flex items-center justify-center gap-3 active:scale-[0.98]">
                <i class="fa-solid fa-barcode text-primary-theme text-xl"></i> 
                <span><%= t('add_dvd.btn_scan') %></span>
            </button>
        </div>

        <div id="reader" class="hidden mt-6 w-full rounded-xl overflow-hidden border-2 border-primary-theme shadow-[0_0_20px_rgba(34,197,94,0.3)] bg-black"></div>
    </div>

    <% if (locals.results) { %>
        <div class="mb-4 flex items-center justify-between">
            <h2 class="text-xl font-bold transition-colors"><%= t('add_dvd.results_title') %></h2>
            <span class="bg-black/10 dark:bg-white/10 text-xs font-mono px-2 py-1 rounded opacity-70 transition-colors"><%= results.length %></span>
        </div>

        <% if (results.length === 0) { %>
            <div class="text-center py-12 card-theme bg-opacity-50 rounded-xl border-dashed opacity-70 transition-colors">
                <i class="fa-solid fa-ghost text-4xl mb-3 opacity-50"></i>
                <p><%= t('add_dvd.no_results') %></p>
            </div>
        <% } else { %>
            <div class="grid grid-cols-2 md:grid-cols-3 lg:grid-cols-4 gap-4">
                <% results.forEach(item => { %>
                    <a href="/confirm-dvd/<%= item.media_type %>/<%= item.tmdb_id %><%= locals.scanned_barcode ? '?barcode=' + locals.scanned_barcode : '' %>" class="card-theme rounded-xl overflow-hidden hover:border-primary-theme transition-all group flex flex-col hover:shadow-lg hover:-translate-y-1">
                        <div class="relative aspect-[2/3] bg-black/5 dark:bg-white/5">
                            <% if(item.cover_image && !item.cover_image.includes('spacer.gif')) { %>
                                <img src="<%= item.cover_image %>" onerror="this.onerror=null; this.src='/ressources/no-pp.jpg';" class="w-full h-full object-cover">
                            <% } else { %>
                                <div class="w-full h-full flex items-center justify-center opacity-30">
                                    <i class="fa-solid fa-film text-3xl"></i>
                                </div>
                            <% } %>
                            
                           <div class="absolute top-2 right-2 bg-black/70 text-white text-[9px] font-bold px-1.5 py-0.5 rounded backdrop-blur-sm uppercase">
                                <%= item.media_type === 'tv' 
                                    ? t('add_dvd.tv_show') 
                                    : t('add_dvd.movie') %>
                            </div>
                        </div>

                        <div class="p-3 flex flex-col flex-grow">
                            <h3 class="font-bold text-sm leading-tight mb-1 line-clamp-2 transition-colors"><%= item.title %></h3>
                            <p class="opacity-40 text-[10px] mb-2 transition-colors"><%= item.year %></p>
                        </div>
                    </a>
                <% }) %>
            </div>
        <% } %>
    <% } %>
</div>

<script>
    const scanTranslations = {
        btnDefault: '<i class="fa-solid fa-barcode text-primary-theme text-xl"></i> <span>' + '<%= t("add_dvd.btn_scan") %>' + '</span>',
        init: '<i class="fa-solid fa-spinner fa-spin text-xl"></i> <span>' + '<%= t("add_dvd.scan_init") %>' + '</span>',
        stop: '<i class="fa-solid fa-xmark text-xl"></i> <span>' + '<%= t("add_dvd.scan_stop") %>' + '</span>',
        found: '<i class="fa-solid fa-check text-xl"></i> <span>' + '<%= t("add_dvd.scan_found") %>' + '</span>',
        error: '<' + '%= t("add_dvd.scan_error") %' + '>'
    };

    const html5QrCode = new Html5Qrcode("reader");
    const scanButton = document.getElementById('start-scan');
    const readerDiv = document.getElementById('reader');
    const searchInput = document.querySelector('input[name="query"]');
    const form = document.querySelector('form[action="/search-dvds"]');
    let isScanning = false;

    scanButton.addEventListener('click', () => {
        if (isScanning) {
            html5QrCode.stop().then(() => {
                readerDiv.classList.add('hidden');
                scanButton.innerHTML = scanTranslations.btnDefault;
                
                scanButton.classList.remove('bg-red-600', 'hover:bg-red-500', 'text-white');
                scanButton.classList.add('bg-black/5', 'dark:bg-white/5', 'hover:bg-black/10', 'dark:hover:bg-white/10');
                
                isScanning = false;
            }).catch(err => console.error("[ERR] stop scan", err));
        } else {
            readerDiv.classList.remove('hidden');
            scanButton.innerHTML = scanTranslations.init;
            
            const config = { 
                fps: 10, 
                qrbox: { width: 250, height: 150 }, 
                aspectRatio: 1.0,
                formatsToSupport: [ 
                    Html5QrcodeSupportedFormats.EAN_13,
                    Html5QrcodeSupportedFormats.EAN_8,
                    Html5QrcodeSupportedFormats.UPC_A,
                    Html5QrcodeSupportedFormats.UPC_E
                ]
            };

            html5QrCode.start(
                { facingMode: "environment" },
                config,
                (decodedText) => {
                    html5QrCode.stop().then(() => {
                        readerDiv.classList.add('hidden');
                        scanButton.innerHTML = scanTranslations.found;
                        searchInput.value = decodedText;
                        form.submit();
                    });
                },
                (errorMessage) => {}
            ).then(() => {
                isScanning = true;
                scanButton.innerHTML = scanTranslations.stop;
                
                scanButton.classList.remove('bg-black/5', 'dark:bg-white/5', 'hover:bg-black/10', 'dark:hover:bg-white/10');
                scanButton.classList.add('bg-red-600', 'hover:bg-red-500', 'text-white');
            }).catch(err => {
                console.error("[ERR] start scan", err);
                scanButton.innerHTML = scanTranslations.error;
            });
        }
    });
</script>

<%- include('partials/footer') %>