<%- include('partials/header') %>

    <script src="https://unpkg.com/html5-qrcode" type="text/javascript"></script>

    <div class="max-w-screen-lg mx-auto pb-20 px-4">

        <div class="text-center mb-8 md:mb-10 pt-6">
            <h1 class="text-2xl md:text-3xl font-bold transition-colors">
                <%= t('add_vinyl.title') %>
            </h1>
            <p class="text-sm md:text-base opacity-60 transition-colors">
                <%= t('add_vinyl.desc') %>
            </p>
        </div>

        <div class="card-theme p-4 md:p-8 rounded-2xl shadow-xl mb-10 transition-colors">

            <form action="/search-discogs" method="POST" class="mb-6">

                <div class="grid grid-cols-3 gap-3 mb-6">
                    <label class="cursor-pointer relative group">
                        <input type="radio" name="type" value="vinyl" class="peer sr-only"
                            <%=(locals.searchType==='vinyl' || !locals.searchType) ? 'checked' : '' %>>
                        <div
                            class="h-full flex flex-col items-center justify-center p-3 md:p-4 rounded-xl border border-transparent bg-black/5 dark:bg-white/5 text-center transition-all peer-checked:bg-green-600 peer-checked:text-white hover:bg-black/10 dark:hover:bg-white/10 opacity-70 peer-checked:opacity-100 peer-checked:shadow-md">
                            <i class="fa-solid fa-record-vinyl text-xl md:text-2xl mb-1 block"></i>
                            <span class="text-sm font-bold">
                                <%= t('media.vinyl') %>
                            </span>
                        </div>
                    </label>

                    <label class="cursor-pointer relative group">
                        <input type="radio" name="type" value="cd" class="peer sr-only" <%=(locals.searchType==='cd' )
                            ? 'checked' : '' %>>
                        <div
                            class="h-full flex flex-col items-center justify-center p-3 md:p-4 rounded-xl border border-transparent bg-black/5 dark:bg-white/5 text-center transition-all peer-checked:bg-blue-600 peer-checked:text-white hover:bg-black/10 dark:hover:bg-white/10 opacity-70 peer-checked:opacity-100 peer-checked:shadow-md">
                            <i class="fa-solid fa-compact-disc text-xl md:text-2xl mb-1 block"></i>
                            <span class="text-sm font-bold">
                                <%= t('media.cd') %>
                            </span>
                        </div>
                    </label>

                    <label class="cursor-pointer relative group">
                        <input type="radio" name="type" value="cassette" class="peer sr-only" <%=(typeof searchType
                            !=='undefined' && searchType==='cassette' ) ? 'checked' : '' %>>
                        <div
                            class="h-full flex flex-col items-center justify-center p-3 md:p-4 rounded-xl border border-transparent bg-black/5 dark:bg-white/5 text-center transition-all peer-checked:bg-orange-600 peer-checked:text-white hover:bg-black/10 dark:hover:bg-white/10 opacity-70 peer-checked:opacity-100 peer-checked:shadow-md">
                            <svg xmlns="http://www.w3.org/2000/svg" width="24" height="24" viewBox="0 0 24 24"
                                fill="none" stroke="currentColor" stroke-width="2" stroke-linecap="round"
                                stroke-linejoin="round" class="mx-auto mb-1">
                                <rect width="20" height="16" x="2" y="4" rx="2" />
                                <circle cx="8" cy="10" r="2" />
                                <path d="M8 12h8" />
                                <circle cx="16" cy="10" r="2" />
                                <path d="m6 20 .7-2.9A1.4 1.4 0 0 1 8.1 16h7.8a1.4 1.4 0 0 1 1.4 1l.7 3" />
                            </svg>
                            <span class="text-sm font-bold">
                                <%= t('media.cassette') %>
                            </span>
                        </div>
                    </label>
                </div>

                <div class="flex flex-col md:flex-row gap-3">
                    <div class="relative flex-grow">
                        <div class="absolute inset-y-0 left-0 flex items-center pl-4 pointer-events-none">
                            <i class="fa-solid fa-search opacity-50"></i>
                        </div>
                        <input type="text" name="query" value="<%= locals.searchQuery || '' %>"
                            class="block w-full p-4 pl-12 border border-transparent rounded-xl bg-black/5 dark:bg-white/5 focus:ring-2 focus:ring-primary-theme focus:bg-transparent placeholder-opacity-50 text-base transition-all"
                            placeholder="<%= t('add_vinyl.search_placeholder') %>" required autofocus>
                    </div>

                    <button type="submit"
                        class="w-full md:w-auto px-8 py-4 bg-primary-theme text-white font-bold rounded-xl hover:brightness-110 transition-all shadow-lg active:scale-95 duration-100">
                        <%= t('common.search') %>
                    </button>
                </div>

                <!-- Advanced Filters -->
                <div class="mt-4">
                    <button type="button" onclick="document.getElementById('advanced-filters').classList.toggle('hidden'); document.getElementById('filter-icon').classList.toggle('fa-chevron-up'); document.getElementById('filter-icon').classList.toggle('fa-chevron-down')" class="text-xs md:text-sm opacity-70 hover:opacity-100 flex items-center gap-2 transition-opacity font-medium">
                        <i id="filter-icon" class="fa-solid fa-chevron-down"></i> <%= t('add_vinyl.advanced_filters') || 'Filtres avancés' %>
                    </button>
                    <div id="advanced-filters" class="hidden mt-4 p-4 rounded-xl border border-black/10 dark:border-white/10 bg-black/5 dark:bg-white/5 grid grid-cols-2 md:grid-cols-4 gap-4">
                        <div>
                            <label class="block text-xs font-bold mb-1 opacity-70"><%= t('add_vinyl.filter_year') || 'Année' %></label>
                            <input type="number" name="year" class="w-full p-2 text-sm rounded-lg bg-white dark:bg-black/50 border border-transparent focus:ring-2 focus:ring-primary-theme outline-none" placeholder="<%= t('add_vinyl.filter_ex_year') || 'Ex: 1994' %>">
                        </div>
                        <div>
                            <label class="block text-xs font-bold mb-1 opacity-70"><%= t('add_vinyl.filter_country') || 'Pays' %></label>
                            <input type="text" name="country" class="w-full p-2 text-sm rounded-lg bg-white dark:bg-black/50 border border-transparent focus:ring-2 focus:ring-primary-theme outline-none" placeholder="<%= t('add_vinyl.filter_ex_country') || 'Ex: UK' %>">
                        </div>
                        <div>
                            <label class="block text-xs font-bold mb-1 opacity-70"><%= t('add_vinyl.filter_genre') || 'Genre' %></label>
                            <input type="text" name="genre_filter" class="w-full p-2 text-sm rounded-lg bg-white dark:bg-black/50 border border-transparent focus:ring-2 focus:ring-primary-theme outline-none" placeholder="<%= t('add_vinyl.filter_ex_genre') || 'Ex: Electronic' %>">
                        </div>
                        <div>
                            <label class="block text-xs font-bold mb-1 opacity-70"><%= t('add_vinyl.filter_label') || 'Label' %></label>
                            <input type="text" name="label_filter" class="w-full p-2 text-sm rounded-lg bg-white dark:bg-black/50 border border-transparent focus:ring-2 focus:ring-primary-theme outline-none" placeholder="<%= t('add_vinyl.filter_ex_label') || 'Ex: EMI' %>">
                        </div>
                    </div>
                </div>
            </form>

            <div class="relative flex py-4 items-center">
                <div class="flex-grow border-t border-black/10 dark:border-white/10 transition-colors"></div>
                <span
                    class="flex-shrink-0 mx-4 opacity-50 text-xs font-bold uppercase tracking-widest transition-colors">
                    <%= t('add_vinyl.separator_or') %>
                </span>
                <div class="flex-grow border-t border-black/10 dark:border-white/10 transition-colors"></div>
            </div>

            <div class="mt-2">
                <button id="start-scan" type="button"
                    class="w-full py-4 text-base font-bold bg-black/5 dark:bg-white/5 border border-transparent rounded-xl hover:bg-black/10 dark:hover:bg-white/10 focus:ring-4 focus:ring-primary-theme/30 transition-all flex items-center justify-center gap-3 active:scale-[0.98]">
                    <i class="fa-solid fa-barcode text-primary-theme text-xl"></i>
                    <span>
                        <%= t('add_vinyl.btn_scan') %>
                    </span>
                </button>
            </div>

            <div id="reader"
                class="hidden mt-6 w-full rounded-xl overflow-hidden border-2 border-primary-theme shadow-[0_0_20px_rgba(34,197,94,0.3)] bg-black">
            </div>
        </div>

        <% if (locals.results) { %>
            <div class="mb-4 flex items-center justify-between">
                <h2 class="text-xl font-bold transition-colors">
                    <%= t('add_vinyl.results_title') %>
                </h2>
                <span
                    class="bg-black/10 dark:bg-white/10 text-xs font-mono px-2 py-1 rounded opacity-70 transition-colors">
                    <%= results.length %>
                </span>
            </div>

            <% if (results.length===0) { %>
                <div
                    class="text-center py-12 card-theme bg-opacity-50 rounded-xl border-dashed opacity-70 transition-colors">
                    <i class="fa-solid fa-ghost text-4xl mb-3 opacity-50"></i>
                    <p>
                        <%= t('add_vinyl.no_results') %>
                    </p>
                </div>
                <% } else { %>
                    <div class="grid grid-cols-2 md:grid-cols-3 lg:grid-cols-4 gap-4">
                        <% results.forEach(item=> { %>
                            <a href="/confirm-vinyl/<%= item.id %><%= locals.searchType ? '?type=' + locals.searchType : '' %>"
                                class="card-theme rounded-xl overflow-hidden hover:border-primary-theme transition-all group flex flex-col hover:shadow-lg hover:-translate-y-1">
                                <div class="relative aspect-square bg-black/5 dark:bg-white/5">
                                    <% if(item.cover_image && !item.cover_image.includes('spacer.gif')) { %>
                                        <img src="<%= item.cover_image %>" class="w-full h-full object-cover">
                                        <% } else { %>
                                            <div class="w-full h-full flex items-center justify-center opacity-30">
                                                <i class="fa-solid fa-compact-disc text-3xl"></i>
                                            </div>
                                            <% } %>
                                </div>

                                <div class="p-3 flex flex-col flex-grow">
                                    <h3 class="font-bold text-sm leading-tight mb-1 line-clamp-2 transition-colors">
                                        <%= item.title %>
                                    </h3>

                                    <p class="opacity-60 text-[10px] mb-2 transition-colors">
                                        <%= item.country ? item.country + ' • ' : '' %>
                                            <%= item.year %>
                                    </p>

                                    <% if(item.is_advanced_cd) { %>
                                        <div class="flex items-center gap-1 mb-2">
                                            <span
                                                class="text-[10px] font-bold text-white px-2 py-0.5 rounded-full shadow-md truncate max-w-full <%= item.is_advanced_cd === 'sacd' ? 'bg-red-600/90' : 'bg-blue-600/90' %>">
                                                <%= item.is_advanced_cd==='sacd' ? t('media.sacd') : t('media.cdr') %>
                                            </span>
                                        </div>
                                        <% } %>

                                            <% if(item.variant_info) { %>
                                                <div class="flex items-center gap-1 mb-3">
                                                    <span
                                                        class="w-2 h-2 rounded-full bg-primary-theme inline-block flex-shrink-0"></span>
                                                    <span
                                                        class="text-[10px] opacity-70 truncate max-w-full font-medium italic">
                                                        <%= item.variant_info %>
                                                    </span>
                                                </div>
                                                <% } %>

                                                    <div class="flex flex-wrap gap-1 mt-auto">
                                                        <% if(item.format) { %>
                                                            <% item.format.slice(0, 2).forEach(fmt=> { %>
                                                                <span
                                                                    class="text-[9px] bg-black/5 dark:bg-white/10 opacity-70 px-1.5 py-0.5 rounded border border-transparent truncate max-w-full transition-colors">
                                                                    <%= fmt %>
                                                                </span>
                                                                <% }) %>
                                                                    <% } %>
                                                    </div>
                                </div>
                            </a>
                            <% }) %>
                    </div>
                    <% } %>
                        <% } %>
    </div>

    <script>
        const scanTranslations = {
            btnDefault: '<i class="fa-solid fa-barcode text-primary-theme text-xl"></i> <span><%= t("add_vinyl.btn_scan") %></span>',
            init: '<i class="fa-solid fa-spinner fa-spin text-xl"></i> <span><%= t("add_vinyl.scan_init") %></span>',
            stop: '<i class="fa-solid fa-xmark text-xl"></i> <span><%= t("add_vinyl.scan_stop") %></span>',
            found: '<i class="fa-solid fa-check text-xl"></i> <span><%= t("add_vinyl.scan_found") %></span>',
            error: '<%= t("add_vinyl.scan_error") %>'
        };

        const html5QrCode = new Html5Qrcode("reader");
        const scanButton = document.getElementById('start-scan');
        const readerDiv = document.getElementById('reader');
        const searchInput = document.querySelector('input[name="query"]');
        const form = document.querySelector('form[action="/search-discogs"]');
        let isScanning = false;

        scanButton.addEventListener('click', () => {
            if (isScanning) {
                html5QrCode.stop().then(() => {
                    readerDiv.classList.add('hidden');
                    scanButton.innerHTML = scanTranslations.btnDefault;

                    scanButton.classList.remove('bg-red-600', 'hover:bg-red-500', 'text-white');
                    scanButton.classList.add('bg-black/5', 'dark:bg-white/5', 'hover:bg-black/10', 'dark:hover:bg-white/10');

                    isScanning = false;
                }).catch(err => console.error("Erreur stop scan", err));
            } else {
                readerDiv.classList.remove('hidden');
                scanButton.innerHTML = scanTranslations.init;

                const config = {
                    fps: 10,
                    qrbox: { width: 250, height: 150 },
                    aspectRatio: 1.0,
                    formatsToSupport: [
                        Html5QrcodeSupportedFormats.EAN_13,
                        Html5QrcodeSupportedFormats.UPC_A,
                        Html5QrcodeSupportedFormats.UPC_E
                    ]
                };
                html5QrCode.start(
                    { facingMode: "environment" },
                    config,
                    (decodedText) => {
                        html5QrCode.stop().then(() => {
                            readerDiv.classList.add('hidden');
                            scanButton.innerHTML = scanTranslations.found;
                            searchInput.value = decodedText;
                            form.submit();
                        });
                    },
                    (errorMessage) => { }
                ).then(() => {
                    isScanning = true;
                    scanButton.innerHTML = scanTranslations.stop;

                    scanButton.classList.remove('bg-black/5', 'dark:bg-white/5', 'hover:bg-black/10', 'dark:hover:bg-white/10');
                    scanButton.classList.add('bg-red-600', 'hover:bg-red-500', 'text-white');
                }).catch(err => {
                    console.error("Erreur start scan", err);
                    scanButton.innerHTML = scanTranslations.error;
                });
            }
        });
    </script>

    <%- include('partials/footer') %>