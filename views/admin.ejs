<%- include('partials/header') %>

<div class="max-w-screen-xl mx-auto px-4 pb-20 space-y-10">

    <div class="flex flex-col sm:flex-row sm:items-center justify-between py-6 gap-4">
        <h1 class="text-2xl md:text-3xl font-bold flex items-center gap-3 transition-colors">
            <i class="fa-solid fa-shield-halved text-primary-theme"></i> <%= t('admin.title') %>
        </h1>
    </div>

    <div class="flex flex-col sm:flex-row sm:items-center justify-between gap-4">
        <h1 class="text-2xl md:text-3xl font-bold flex items-center gap-3 transition-colors">
            <i class="fa-solid fa-puzzle-piece text-primary-theme"></i> <%= t('admin.modules') %>
        </h1>
    </div>

    <section class="card-theme rounded-3xl p-6 shadow-sm mb-10 transition-colors">
        <div class="flex flex-col gap-8">
            
            <div class="flex items-center gap-4">
                <div class="w-12 h-12 rounded-2xl bg-primary-theme/10 text-primary-theme flex items-center justify-center shrink-0">
                    <i class="fa-solid fa-cubes-stacked text-xl"></i>
                </div>
                <div>
                    <h2 class="text-sm font-black uppercase tracking-widest opacity-80"><%= t('perso.modules.title') %></h2>
                    <p class="text-xs opacity-50"><%= t('admin.modules_description') %></p>
                </div>
            </div>

            <form action="/admin/modules/save" method="POST" class="space-y-6">
                <div class="grid grid-cols-1 sm:grid-cols-3 gap-4">
                    <% const mods = [
                        {key: 'music', label: t('perso.modules.music'), icon: 'fa-music'},
                        {key: 'books', label: t('perso.modules.books'), icon: 'fa-book'},
                        {key: 'dvd', label: t('media.dvds'), icon: 'fa-film'}
                    ] %>
                    
                    <% mods.forEach((mod) => { %>
                        <label class="group flex items-center justify-between p-4 rounded-2xl bg-black/5 dark:bg-white/5 border border-transparent hover:border-primary-theme/30 transition-all cursor-pointer">
                            <div class="flex items-center gap-3">
                                <div class="w-10 h-10 rounded-xl flex items-center justify-center bg-white dark:bg-black/20 shadow-sm group-hover:text-primary-theme transition-colors">
                                    <i class="fa-solid <%= mod.icon %> text-sm"></i>
                                </div>
                                <span class="text-sm font-bold opacity-70 group-hover:opacity-100 transition-opacity"><%= mod.label %></span>
                            </div>
                            
                            <div class="relative inline-flex items-center cursor-pointer">
                                <input type="checkbox" name="<%= mod.key %>Active" <%= settings.modules[mod.key] ? 'checked' : '' %> class="sr-only peer">
                                <div class="w-11 h-6 bg-black/10 dark:bg-white/10 peer-focus:outline-none rounded-full peer peer-checked:after:translate-x-full peer-checked:after:border-white after:content-[''] after:absolute after:top-[2px] after:left-[2px] after:bg-white after:rounded-full after:h-5 after:w-5 after:transition-all peer-checked:bg-primary-theme"></div>
                            </div>
                        </label>
                    <% }) %>
                </div>

                <div class="flex justify-end pt-2">
                    <button type="submit" class="w-full sm:w-auto bg-primary-theme text-white text-xs font-black uppercase tracking-widest px-10 py-4 rounded-2xl hover:brightness-110 active:scale-95 transition-all shadow-lg shadow-primary-theme/20 flex items-center justify-center gap-3">
                        <i class="fa-solid fa-save"></i> 
                        <%= t('perso.save') %>
                    </button>
                </div>
            </form>
        </div>
    </section>

    <% if (locals.newPassword) { %>
        <div class="bg-primary-theme/10 border border-primary-theme/30 p-6 rounded-2xl text-center animate-pulse transition-colors">
            <h2 class="text-lg font-bold text-primary-theme mb-2">
                <i class="fa-solid fa-check-circle"></i> <%= successMessage %>
            </h2>
            <p class="text-sm opacity-70 mb-4"><%= t('admin.temp_password_hint') %></p>
            <div class="bg-white dark:bg-black/50 p-4 rounded-xl inline-flex items-center gap-3 border border-primary-theme/30 shadow-sm overflow-hidden max-w-full">
                <code class="text-xl md:text-2xl font-mono select-all break-all"><%= newPassword %></code>
            </div>
        </div>
    <% } %>

    <section>
        <div class="flex flex-col sm:flex-row sm:items-center justify-between py-6 gap-4 mb-4">
            <h1 class="text-2xl md:text-3xl font-bold flex items-center gap-3 transition-colors">
                <i class="fa-solid fa-users text-neutral-400 dark:text-neutral-500"></i> <%= t('admin.users_count', { count: users.length }) %>
            </h1>
            
            <button onclick="toggleModal('addUserModal')" class="group relative flex items-center gap-3 bg-primary-theme hover:brightness-110 text-white px-5 py-3 rounded-2xl shadow-lg shadow-primary-theme/20 transition-all active:scale-95 overflow-hidden">
                <div class="absolute inset-0 bg-white/10 translate-y-full group-hover:translate-y-0 transition-transform"></div>
                <i class="fa-solid fa-user-plus text-sm relative"></i>
                <span class="text-xs font-black relative"><%= t('admin.modal.title') %></span>
            </button>
        </div>
        
        <div class="hidden md:block card-theme rounded-2xl overflow-hidden shadow-lg transition-colors">
            <table class="w-full text-left text-sm opacity-80">
                <thead class="bg-black/5 dark:bg-white/5 text-xs uppercase opacity-70 transition-colors">
                    <tr>
                        <th class="px-6 py-4"><%= t('admin.table.user') %></th>
                        <th class="px-6 py-4"><%= t('admin.table.email') %></th>
                        <th class="px-6 py-4"><%= t('admin.table.last_change') %></th>
                        <th class="px-6 py-4 text-right"><%= t('admin.table.actions') %></th>
                    </tr>
                </thead>
                <tbody class="divide-y divide-black/5 dark:divide-white/5 transition-colors">
                    <% users.forEach(u => { %>
                        <tr class="hover:bg-black/5 dark:hover:bg-white/5 transition-colors">
                            <td class="px-6 py-4 font-medium flex items-center gap-3">
                                <img src="<%= u.img %>" class="w-8 h-8 rounded-full border border-black/10 dark:border-white/10 object-cover">
                                <%= u.username %>
                            </td>
                            <td class="px-6 py-4"><%= u.email %></td>
                            <td class="px-6 py-4 text-xs opacity-70">
                                <%= new Date(u.lastChange).toLocaleDateString(currentLng === 'fr' ? 'fr-FR' : 'en-US') %>
                            </td>
                            <td class="px-6 py-4 text-right flex justify-end gap-2">
                                <form action="/admin/reset-password" method="POST" onsubmit="return confirm('<%= t('admin.confirm_reset', { name: u.username }) %>')">
                                    <input type="hidden" name="userId" value="<%= u._id %>">
                                    <button type="submit" class="text-yellow-600 bg-yellow-100 dark:bg-yellow-500/10 p-2 rounded-lg transition-colors hover:brightness-110" title="<%= t('admin.tooltips.reset_password') %>">
                                        <i class="fa-solid fa-key"></i>
                                    </button>
                                </form>
                                <% if (u._id.toString() !== user._id.toString()) { %>
                                    <form action="/admin/delete-user" method="POST" onsubmit="return confirm('<%= t('admin.confirm_delete_user', { name: u.username }) %>')">
                                        <input type="hidden" name="userId" value="<%= u._id %>">
                                        <button type="submit" class="text-red-600 bg-red-100 dark:bg-red-500/10 p-2 rounded-lg transition-colors hover:brightness-110" title="<%= t('admin.tooltips.delete') %>">
                                            <i class="fa-solid fa-trash"></i>
                                        </button>
                                    </form>
                                <% } %>
                            </td>
                        </tr>
                    <% }) %>
                </tbody>
            </table>
        </div>

        <div class="md:hidden space-y-4">
            <% users.forEach(u => { %>
                <div class="card-theme p-5 rounded-2xl shadow-sm space-y-4 transition-colors">
                    <div class="flex items-center gap-4">
                        <img src="<%= u.img %>" class="w-12 h-12 rounded-full border border-black/10 dark:border-white/10 object-cover">
                        <div class="overflow-hidden">
                            <p class="font-bold truncate"><%= u.username %></p>
                            <p class="text-xs opacity-60 truncate"><%= u.email %></p>
                        </div>
                    </div>

                    <div class="flex items-center justify-between pt-4 border-t border-black/5 dark:border-white/5">
                        <div class="flex flex-col">
                            <span class="text-[9px] opacity-50 uppercase font-bold tracking-wider">
                                <%= t('admin.table.last_change') %>
                            </span>
                            <span class="text-xs opacity-70">
                                <%= new Date(u.lastChange).toLocaleDateString(currentLng === 'fr' ? 'fr-FR' : 'en-US') %>
                            </span>
                        </div>

                        <div class="flex gap-2">
                            <form action="/admin/reset-password" method="POST" onsubmit="return confirm('<%= t('admin.confirm_reset', { name: u.username }) %>')">
                                <input type="hidden" name="userId" value="<%= u._id %>">
                                <button type="submit" class="text-yellow-600 bg-yellow-50 dark:bg-yellow-500/10 px-4 py-2 rounded-xl border border-yellow-200 dark:border-yellow-500/20 text-sm font-bold">
                                    <i class="fa-solid fa-key"></i>
                                </button>
                            </form>
                            <% if (u._id.toString() !== user._id.toString()) { %>
                                <form action="/admin/delete-user" method="POST" onsubmit="return confirm('<%= t('admin.confirm_delete_user', { name: u.username }) %>')">
                                    <input type="hidden" name="userId" value="<%= u._id %>">
                                    <button type="submit" class="text-red-600 bg-red-50 dark:bg-red-500/10 px-4 py-2 rounded-xl border border-red-200 dark:border-red-500/20 text-sm font-bold">
                                        <i class="fa-solid fa-trash"></i>
                                    </button>
                                </form>
                            <% } %>
                        </div>
                    </div>
                </div>
            <% }) %>
        </div>
    </section>

    <section>
        <h2 class="text-xl font-bold mb-6 flex items-center gap-2 transition-colors">
            <i class="fa-solid fa-ban text-red-500"></i> <%= t('admin.blocked_ips_title', { count: blockedIps.length }) %>
        </h2>

        <% if(blockedIps.length > 0) { %>
            <div class="grid grid-cols-1 sm:grid-cols-2 lg:grid-cols-3 gap-4">
                <% blockedIps.forEach(ip => { %>
                    <div class="card-theme p-5 rounded-2xl flex justify-between items-center group hover:border-red-500/50 transition-colors shadow-sm">
                        <div class="overflow-hidden">
                            <span class="block font-mono font-bold truncate"><%= ip.ip %></span>
                            <span class="text-[10px] opacity-50 uppercase tracking-tighter"><%= new Date(ip.createdAt).toLocaleDateString(currentLng === 'fr' ? 'fr-FR' : 'en-US') %></span>
                        </div>
                        <form action="/admin/unblock-ip" method="POST">
                            <input type="hidden" name="ipId" value="<%= ip._id %>">
                            <button type="submit" class="h-10 w-10 flex items-center justify-center bg-black/5 dark:bg-white/5 opacity-60 hover:text-green-500 hover:opacity-100 rounded-xl transition-colors" title="<%= t('admin.tooltips.unblock') %>">
                                <i class="fa-solid fa-lock-open"></i>
                            </button>
                        </form>
                    </div>
                <% }) %>
            </div>
        <% } else { %>
            <div class="p-12 border-2 border-dashed border-black/10 dark:border-white/10 rounded-3xl text-center opacity-50 transition-colors">
                <i class="fa-solid fa-shield-check text-4xl mb-3 opacity-30 block"></i>
                <%= t('admin.no_blocked_ips') %>
            </div>
        <% } %>
    </section>
    
    <section class="card-theme rounded-3xl p-6 md:p-8 shadow-sm transition-colors mt-6">
        <div class="flex flex-col md:flex-row md:items-center justify-between gap-6">
            <div>
                <h2 class="text-xl font-bold flex items-center gap-2 mb-2">
                    <i class="fa-solid fa-record-vinyl text-primary-theme"></i> <%= t('admin.import.title') %>
                </h2>
                <p class="text-sm opacity-60">
                    <%= t('admin.import.subtitle') %>
                </p>
            </div>
            
            <div class="flex flex-wrap gap-3">
                <button onclick="openImportModal('collection')" class="flex-1 sm:flex-none bg-black/5 dark:bg-white/5 hover:bg-primary-theme hover:text-white px-6 py-3 rounded-xl font-bold text-sm transition-all flex items-center justify-center gap-2">
                    <i class="fa-solid fa-record-vinyl"></i> <%= t('admin.import.collection') %>
                </button>

                <button onclick="openImportModal('wishlist')" class="flex-1 sm:flex-none bg-black/5 dark:bg-white/5 hover:bg-primary-theme hover:text-white px-6 py-3 rounded-xl font-bold text-sm transition-all flex items-center justify-center gap-2">
                    <i class="fa-solid fa-heart"></i> <%= t('admin.import.wantlist') %>
                </button>
            </div>
        </div>
    </section>

    <section class="card-theme rounded-3xl p-6 md:p-8 shadow-sm transition-colors">
        <div class="flex flex-col md:flex-row md:items-center justify-between gap-6">
            <div>
                <h2 class="text-xl font-bold flex items-center gap-2 mb-2">
                    <i class="fa-solid fa-database text-primary-theme"></i> <%= t('admin.backup.title') %>
                </h2>
                <p class="text-sm opacity-60">
                    <%= t('admin.backup.subtitle') %>
                </p>
            </div>
            
            <div class="flex flex-wrap gap-3">
                <a href="/backup/export" class="flex-1 sm:flex-none bg-black/5 dark:bg-white/5 hover:bg-primary-theme hover:text-white px-6 py-3 rounded-xl font-bold text-sm transition-all flex items-center justify-center gap-2">
                    <i class="fa-solid fa-file-export"></i> <%= t('admin.backup.export_btn') %>
                </a>

                <label class="flex-1 sm:flex-none bg-black/5 dark:bg-white/5 hover:bg-yellow-500 hover:text-white px-6 py-3 rounded-xl font-bold text-sm transition-all flex items-center justify-center gap-2 cursor-pointer">
                    <i class="fa-solid fa-file-import"></i> <%= t('admin.backup.import_btn') %>
                    <input type="file" id="backupInput" class="hidden" accept=".json">
                </label>
            </div>
        </div>
    </section>

    <section>
        <div class="flex items-center justify-between mb-6">
            <h2 class="text-xl font-bold flex items-center gap-2 transition-colors">
                <i class="fa-solid fa-satellite-dish text-primary-theme"></i> <%= t('admin.logs_title') %>
            </h2>
            <div class="md:hidden text-[10px] uppercase font-bold opacity-50 flex items-center gap-1">
                <i class="fa-solid fa-left-right animate-pulse"></i> Scroll
            </div>
        </div>

        <div class="card-theme rounded-2xl overflow-hidden shadow-lg transition-colors">
            <div class="overflow-x-auto">
                <table class="w-full text-left text-sm opacity-80 min-w-[700px]">
                    <thead class="bg-black/5 dark:bg-white/5 text-xs uppercase opacity-70 transition-colors">
                        <tr>
                            <th class="px-6 py-4"><%= t('admin.table.user') %></th>
                            <th class="px-6 py-4"><%= t('admin.table.loc') %></th>
                            <th class="px-6 py-4"><%= t('admin.table.ip_device') %></th>
                            <th class="px-6 py-4"><%= t('admin.table.date') %></th>
                            <th class="px-6 py-4 text-right"><%= t('admin.table.security') %></th>
                        </tr>
                    </thead>
                    <tbody class="divide-y divide-black/5 dark:divide-white/5 transition-colors">
                        <% logs.forEach(log => { %>
                            <tr class="hover:bg-black/5 dark:hover:bg-white/5 transition-colors group">
                                <td class="px-6 py-4">
                                    <div class="font-bold"><%= log.username %></div>
                                    <div class="text-[10px] opacity-60 truncate"><%= log.email %></div>
                                </td>
                                <td class="px-6 py-4">
                                    <% if(log.country && log.country !== 'XX') { %>
                                        <div class="flex items-center gap-2">
                                            <img src="https://flagcdn.com/24x18/<%= log.country.toLowerCase() %>.png" class="rounded-sm shadow-sm" alt="Flag">
                                            <span class="font-mono text-xs"><%= log.country %></span>
                                        </div>
                                        <div class="text-[10px] opacity-60 uppercase"><%= log.city %></div>
                                    <% } else { %>
                                        <span class="opacity-50 text-xs"><i class="fa-solid fa-globe"></i> <%= t('admin.local_connection') %></span>
                                    <% } %>
                                </td>
                                <td class="px-6 py-4">
                                    <div class="text-primary-theme font-mono text-xs mb-1"><%= log.ip %></div>
                                    <div class="text-[10px] opacity-60 max-w-[120px] truncate" title="<%= log.userAgent %>">
                                        <%= log.userAgent.includes('Windows') ? 'Windows' : (log.userAgent.includes('Mac') ? 'Mac' : 'Mobile/Linux') %>
                                    </div>
                                </td>
                                <td class="px-6 py-4 text-[10px] whitespace-nowrap">
                                    <% 
                                      const diff = Math.floor((new Date() - new Date(log.timestamp)) / 60000);
                                      let timeText = diff < 60 ? t('admin.time_ago_min', { count: diff }) : new Date(log.timestamp).toLocaleDateString(currentLng === 'fr' ? 'fr-FR' : 'en-US');
                                    %>
                                    <%= timeText %>
                                </td>
                                <td class="px-6 py-4 text-right">
                                    <div class="flex justify-end gap-2 opacity-100 transition-opacity">
                                        <% if (log.user) { %>
                                            <form action="/admin/reset-password" method="POST" onsubmit="return confirm('<%= t('admin.confirm_reset', { name: log.username }) %>')">
                                                <input type="hidden" name="userId" value="<%= log.user %>">
                                                <button type="submit" class="bg-black/5 dark:bg-white/5 hover:bg-yellow-500 hover:text-white p-2 rounded-xl border border-transparent transition-colors" title="<%= t('admin.tooltips.reset_password') %>">
                                                    <i class="fa-solid fa-key"></i>
                                                </button>
                                            </form>
                                        <% } %>
                                        <form action="/admin/block-ip" method="POST" onsubmit="return confirm('<%= t('admin.confirm_block_ip', { ip: log.ip }) %>')">
                                            <input type="hidden" name="ipAddress" value="<%= log.ip %>">
                                            <button type="submit" class="bg-black/5 dark:bg-white/5 hover:bg-red-600 hover:text-white p-2 rounded-xl border border-transparent transition-colors" title="<%= t('admin.tooltips.block') %>">
                                                <i class="fa-solid fa-ban"></i>
                                            </button>
                                        </form>
                                    </div>
                                </td>
                            </tr>
                        <% }) %>
                    </tbody>
                </table>
            </div>
        </div>
    </section>

</div>

<div id="addUserModal" class="fixed inset-0 z-50 hidden bg-black/80 backdrop-blur-md flex items-center justify-center p-6">
    <div class="absolute inset-0" onclick="toggleModal('addUserModal')"></div>

    <div class="card-theme relative w-full max-w-md rounded-[2.5rem] p-8 md:p-10 shadow-2xl transition-all animate-scale-in">
        <button onclick="toggleModal('addUserModal')" class="absolute top-6 right-6 opacity-40 hover:opacity-100 hover:rotate-90 transition-all">
            <i class="fa-solid fa-xmark text-2xl"></i>
        </button>

        <h3 class="text-2xl font-black mb-8"><%= t('admin.modal.title') %></h3>
        
        <form action="/admin/add-user" method="POST" class="space-y-6">
            <div class="space-y-2">
                <label class="block text-[10px] font-black uppercase tracking-widest opacity-50 ml-1"><%= t('admin.modal.username') %></label>
                <input type="text" name="username" required placeholder="Ex: John" class="w-full bg-black/5 dark:bg-white/5 border-2 border-transparent focus:border-primary-theme/30 rounded-2xl p-4 outline-none transition-all placeholder:opacity-30">
            </div>

            <div class="space-y-2">
                <label class="block text-[10px] font-black uppercase tracking-widest opacity-50 ml-1"><%= t('admin.modal.email') %></label>
                <input type="email" name="email" required placeholder="email@domaine.com" class="w-full bg-black/5 dark:bg-white/5 border-2 border-transparent focus:border-primary-theme/30 rounded-2xl p-4 outline-none transition-all placeholder:opacity-30">
            </div>
            
            <button type="submit" class="w-full bg-primary-theme text-white font-black py-5 rounded-2xl shadow-lg shadow-primary-theme/20 hover:brightness-110 active:scale-95 transition-all mt-4">
                <%= t('admin.modal.submit') %>
            </button>
        </form>
    </div>
</div>

<div id="importDiscogsModal" class="fixed inset-0 z-50 hidden bg-black/80 backdrop-blur-md flex items-center justify-center p-6">
    <div class="absolute inset-0" onclick="toggleModal('importDiscogsModal')"></div>

    <div class="card-theme relative w-full max-w-md rounded-[2.5rem] p-8 md:p-10 shadow-2xl transition-all animate-scale-in overflow-hidden">
        
        <button onclick="toggleModal('importDiscogsModal')" class="absolute top-6 right-6 opacity-40 hover:opacity-100 hover:rotate-90 transition-all z-20">
            <i class="fa-solid fa-xmark text-2xl"></i>
        </button>

        <h3 class="text-2xl font-black mb-2 relative z-10">
            <span id="importModalTitle">Import Discogs</span>
        </h3>
        <p class="text-sm opacity-60 mb-8"><%= t('admin.modal.import_subtitle') %></p>

        <div id="importError" class="hidden bg-red-500/10 border border-red-500/20 text-red-400 p-4 rounded-2xl mb-6 text-sm flex items-start gap-3 relative z-10">
            <i class="fa-solid fa-circle-exclamation mt-0.5"></i>
            <span id="importErrorText"></span>
        </div>

        <div class="space-y-6 relative z-10">
            <input type="hidden" id="importType" value="collection">

            <div class="space-y-2">
                <label class="block text-[10px] font-black uppercase tracking-widest opacity-50 ml-1"><%= t('admin.modal.discogs_url') %></label>
                <input type="text" id="discogsUrl" placeholder="https://www.discogs.com/user/..." class="w-full bg-black/5 dark:bg-white/5 border-2 border-transparent focus:border-primary-theme/30 rounded-2xl p-4 outline-none transition-all placeholder:opacity-30">
            </div>
            
            <div class="flex flex-col gap-3 mt-6">
                <button id="btnFastImport" onclick="startDiscogsImport(false)" class="w-full bg-black/5 dark:bg-white/5 hover:bg-black/10 dark:hover:bg-white/10 font-bold py-4 rounded-2xl transition-all active:scale-95 flex items-center justify-center gap-2">
                    <i class="fa-solid fa-bolt text-yellow-500"></i>
                    <span><%= t('admin.modal.import_fast') %></span>
                </button>

                <button id="btnFullImport" onclick="startDiscogsImport(true)" class="w-full bg-primary-theme text-white font-black py-4 rounded-2xl shadow-lg shadow-primary-theme/20 hover:brightness-110 active:scale-95 transition-all flex items-center justify-center gap-2">
                    <i class="fa-solid fa-list-ul"></i>
                    <span><%= t('admin.modal.import_full') %></span>
                </button>
                
                <p class="text-[10px] opacity-40 text-center uppercase tracking-widest mt-2 px-4">
                    <%= t('admin.modal.import_warning') %>
                </p>
            </div>
        </div>
    </div>
</div>


<%- include('partials/footer') %>

<script src="/socket.io/socket.io.js"></script>
<script>
    function toggleModal(id) {
        const modal = document.getElementById(id);
        modal.classList.toggle('hidden');
        if (!modal.classList.contains('hidden')) {
            document.body.style.overflow = 'hidden';
        } else {
            document.body.style.overflow = 'auto';
        }
    }

    document.getElementById('backupInput').onchange = function(e) {
        const file = e.target.files[0];
        if (!file) return;

        const confirmMsg = "<%= t('admin.backup.confirm_import') %>";
        
        if (confirm(confirmMsg)) {
            const reader = new FileReader();
            reader.onload = async (event) => {
                try {
                    const backupData = JSON.parse(event.target.result);
                    const response = await fetch('/backup/import', {
                        method: 'POST',
                        headers: { 'Content-Type': 'application/json' },
                        body: JSON.stringify(backupData)
                    });

                    if (response.ok) {
                        alert("<%= t('admin.backup.import_success') %>");
                        window.location.href = '/login';
                    } else {
                        alert("<%= t('admin.backup.import_error') %>");
                    }
                } catch (err) {
                    alert("<%= t('admin.backup.json_error') %>");
                }
            };
            reader.readAsText(file);
        }
        this.value = ''; // Reset input
    };

    const socket = io();

    socket.on('import_progress', (data) => {
        const btnFast = document.getElementById('btnFastImport');
        const btnFull = document.getElementById('btnFullImport');
        const activeBtn = btnFull.disabled ? btnFull : btnFast;
        
        activeBtn.innerHTML = `<i class="fa-solid fa-circle-notch fa-spin mr-2"></i> Importation : ${data.current}...`;
    });

    socket.on('import_finished', (data) => {
        alert(`${data.count} <%= t('admin.modal.import_done') %>`);
        window.location.reload();
    });

    socket.on('import_error', (data) => {
        const errorBox = document.getElementById('importError');
        const errorText = document.getElementById('importErrorText');
        errorText.innerText = data.message;
        errorBox.classList.remove('hidden');
    });
    
    function openImportModal(type) {
        const titleEl = document.getElementById('importModalTitle');
        const inputType = document.getElementById('importType');
        
        inputType.value = type;
        
        if(type === 'wishlist') {
            titleEl.innerHTML = '<i class="fa-solid fa-heart text-primary-theme mr-2"></i> <%= t('admin.import.wantlist') %>';
        } else {
            titleEl.innerHTML = '<i class="fa-solid fa-record-vinyl text-primary-theme mr-2"></i> <%= t('admin.import.collection') %>';
        }
        
        toggleModal('importDiscogsModal');
    }

    async function startDiscogsImport(isFull) {
        const urlInput = document.getElementById('discogsUrl');
        const btnFast = document.getElementById('btnFastImport');
        const btnFull = document.getElementById('btnFullImport');
        const errorBox = document.getElementById('importError');
        const importType = document.getElementById('importType').value;
        
        if (!urlInput.value) return;

        errorBox.classList.add('hidden');
        
        [btnFast, btnFull].forEach(b => {
            b.disabled = true;
            b.classList.add('opacity-50');
        });

        const activeBtn = isFull ? btnFull : btnFast;
        activeBtn.innerHTML = `<i class="fa-solid fa-circle-notch fa-spin mr-2"></i> <%= t('admin.modal.import_loading') %>`;

        try {
            const response = await fetch('/import/discogs', {
                method: 'POST',
                headers: { 'Content-Type': 'application/json' },
                body: JSON.stringify({ discogsUrl: urlInput.value, full: isFull, type: importType })
            });

            if (!response.ok) {
                const data = await response.json();
                throw new Error(data.error || "Error");
            }

            activeBtn.innerHTML = `<i class="fa-solid fa-spinner fa-spin mr-2"></i> <%= t('admin.modal.import_started') %>`;

        } catch (err) {
            document.getElementById('importErrorText').innerText = err.message;
            errorBox.classList.remove('hidden');
            [btnFast, btnFull].forEach(b => {
                b.disabled = false;
                b.classList.remove('opacity-50');
            });
        }
    }
    document.addEventListener('DOMContentLoaded', () => {
        const moduleCheckboxes = document.querySelectorAll('input[name="musicActive"], input[name="booksActive"], input[name="dvdActive"]');

        moduleCheckboxes.forEach(checkbox => {
            checkbox.addEventListener('change', function() {
                const checkedModules = document.querySelectorAll('input[name="musicActive"]:checked, input[name="booksActive"]:checked, input[name="dvdActive"]:checked');
                
                if (checkedModules.length === 0) {
                    this.checked = true;
                    alert("<%= t('admin.errors.at_least_one_module') %>");
                }
            });
        });
    });
</script>