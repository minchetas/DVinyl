                                        <span class="block font-mono font-bold truncate">
                                            <%= ip.ip %>
                                        </span>
                                        <span class="text-[10px] opacity-50 uppercase tracking-tighter">
                                            <%= new Date(ip.createdAt).toLocaleDateString(currentLng==='fr' ? 'fr-FR'
                                                : 'en-US' ) %>
                                        </span>
                                    </div>
                                    <form action="<%= baseUrl %>/admin/unblock-ip" method="POST">
                                        <input type="hidden" name="ipId" value="<%= ip._id %>">
