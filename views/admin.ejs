                    <div class="flex items-start gap-3 text-sm opacity-70">
                        <span
                            class="bg-primary-theme text-white text-[10px] font-black w-5 h-5 rounded-full flex items-center justify-center shrink-0 mt-0.5">4</span>
                        <span>
                            <%= t('admin.goodreads.step4') %>
                        </span>
                    </div>
                </div>
            </div>

            <div class="mb-6">
                <label class="block text-[10px] font-black uppercase tracking-widest opacity-50 mb-2">
                    <%= t('admin.goodreads.default_format') %>
                </label>
                <p class="text-xs opacity-40 mb-3">
                    <%= t('admin.goodreads.default_format_hint') %>
                </p>
                <select id="goodreadsDefaultFormat"
                    class="bg-black/5 dark:bg-white/5 border border-transparent text-gray-900 dark:text-white text-sm rounded-lg focus:ring-primary-theme focus:border-primary-theme block w-full p-3 transition-colors outline-none cursor-pointer">
                    <option class="bg-white dark:bg-[#1a1a1a]" value="paperback">
                        <%= t('format.paperback') %>
                    </option>
                    <option class="bg-white dark:bg-[#1a1a1a]" value="hardcover">
                        <%= t('format.hardcover') %>
                    </option>
                    <option class="bg-white dark:bg-[#1a1a1a]" value="manga">
                        <%= t('format.manga') %>
                    </option>
                    <option class="bg-white dark:bg-[#1a1a1a]" value="comic">
                        <%= t('format.comic') %>
                    </option>
                    <option class="bg-white dark:bg-[#1a1a1a]" value="graphic_novel">
                        <%= t('format.graphic_novel') %>
                    </option>
                </select>
            </div>

            <div class="mb-6">
                <label class="block text-[10px] font-black uppercase tracking-widest opacity-50 mb-2">
                    <%= t('admin.goodreads.default_language') %>
                </label>
                <input type="text" id="goodreadsDefaultLanguage" placeholder="fr, en, ja..." maxlength="5"
                    class="w-full bg-black/5 dark:bg-white/5 border-2 border-transparent focus:border-primary-theme/30 rounded-2xl p-4 outline-none transition-all text-sm placeholder:opacity-30">
                <p class="text-[10px] opacity-40 mt-2">
                    <%= t('admin.goodreads.default_language_hint') %>
                </p>
            </div>

            <div class="mb-6">
                <label class="block text-[10px] font-black uppercase tracking-widest opacity-50 mb-2">
                    <%= t('admin.goodreads.rss_url_label') %>
                </label>
                <input type="url" id="goodreadsRssUrl" placeholder="https://www.goodreads.com/review/list_rss/..."
                    class="w-full bg-black/5 dark:bg-white/5 border-2 border-transparent focus:border-primary-theme/30 rounded-2xl p-4 outline-none transition-all text-sm placeholder:opacity-30"
                    oninput="onGoodreadsUrlInput(this.value)">
                <p class="text-[10px] opacity-40 mt-2">
                    <%= t('admin.goodreads.rss_url_hint') %>
                </p>
            </div>

            <div id="goodreadsError"
                class="hidden bg-red-500/10 border border-red-500/20 text-red-400 p-4 rounded-2xl mb-6 text-sm flex items-start gap-3">
                <i class="fa-solid fa-circle-exclamation mt-0.5"></i>
                <span id="goodreadsErrorText"></span>
            </div>

            <div id="goodreadsWarning"
                class="hidden bg-yellow-500/10 border border-yellow-500/20 rounded-2xl p-4 mb-4 flex items-start gap-3">
                <i class="fa-solid fa-clock text-yellow-500 mt-0.5 shrink-0"></i>
                <div>
                    <p class="text-xs font-bold opacity-80">
                        <%= t('admin.goodreads.warning_title') %>
                    </p>
                    <p class="text-[11px] opacity-60 mt-1">
                        <%= t('admin.goodreads.warning_body') %>
                    </p>
                </div>
            </div>

            <button id="btnGoodreadsImport" onclick="startGoodreadsImport()" disabled
                class="w-full bg-primary-theme text-white font-black py-4 rounded-2xl shadow-lg shadow-primary-theme/20 hover:brightness-110 active:scale-95 transition-all flex items-center justify-center gap-2 disabled:opacity-40 disabled:cursor-not-allowed disabled:active:scale-100">
                <i class="fa-solid fa-rss"></i>
                <span>
                    <%= t('admin.goodreads.btn_import') %>
                </span>
            </button>
        </div>
    </div>

    <%- include('partials/footer') %>

        <script src="<%= baseUrl %>/socket.io/socket.io.js"></script>
        <script>
            function toggleModal(id) {
                const modal = document.getElementById(id);
                modal.classList.toggle('hidden');
                document.body.style.overflow = modal.classList.contains('hidden') ? 'auto' : 'hidden';
            }

            document.getElementById('backupInput').onchange = function (e) {
                const file = e.target.files[0];
                if (!file) return;
                if (confirm("<%= t('admin.backup.confirm_import') %>")) {
                    const reader = new FileReader();
                    reader.onload = async (event) => {
                        try {
                            const backupData = JSON.parse(event.target.result);
                            const response = await fetch('<%= baseUrl %>/backup/import', {
                                method: 'POST',
                                headers: { 'Content-Type': 'application/json' },
                                body: JSON.stringify(backupData)
                            });
                            if (response.ok) {
                                alert("<%= t('admin.backup.import_success') %>");
                                window.location.href = '<%= baseUrl %>/login';
                            } else {
                                alert("<%= t('admin.backup.import_error') %>");
                            }
                        } catch (err) {
                            alert("<%= t('admin.backup.json_error') %>");
                        }
                    };
                    reader.readAsText(file);
                }
                this.value = '';
            };

            const btnGoodreadsImport = document.getElementById('btnGoodreadsImport');

            function onGoodreadsUrlInput(val) {
                const isValid = val.includes('goodreads.com');
                if (btnGoodreadsImport) btnGoodreadsImport.disabled = !isValid;

                const warning = document.getElementById('goodreadsWarning');
                if (warning) warning.classList.toggle('hidden', !isValid);
            }

            async function startGoodreadsImport() {
                const rssUrl = document.getElementById('goodreadsRssUrl')?.value?.trim();
                const defaultFormat = document.getElementById('goodreadsDefaultFormat')?.value || 'paperback';
                const defaultLanguage = document.getElementById('goodreadsDefaultLanguage')?.value?.trim() || '';
                if (!rssUrl) return;

                const errorBox = document.getElementById('goodreadsError');
                const errorText = document.getElementById('goodreadsErrorText');
                errorBox.classList.add('hidden');
                btnGoodreadsImport.disabled = true;
                btnGoodreadsImport.innerHTML = '<i class="fa-solid fa-circle-notch fa-spin mr-2"></i> <%= t("admin.modal.import_loading") %>';

                try {
                    const response = await fetch('<%= baseUrl %>/import/goodreads', {
                        method: 'POST',
                        headers: { 'Content-Type': 'application/json' },
                        body: JSON.stringify({ rss_url: rssUrl, default_format: defaultFormat, default_language: defaultLanguage })
                    });
                    if (!response.ok) {
                        const data = await response.json();
                        throw new Error(data.error || 'Error');
                    }
                    btnGoodreadsImport.innerHTML = '<i class="fa-solid fa-spinner fa-spin mr-2"></i> <%= t("admin.modal.import_started") %>';
                } catch (err) {
                    errorText.innerText = err.message;
                    errorBox.classList.remove('hidden');
                    btnGoodreadsImport.disabled = false;
                    btnGoodreadsImport.innerHTML = '<i class="fa-solid fa-rss mr-2"></i> <%= t("admin.goodreads.btn_import") %>';
                }
            }

            const socket = io({
                path: '<%= baseUrl %>/socket.io',
            });

            socket.on('import_progress', (data) => {

                // Discogs
                const btnFast = document.getElementById('btnFastImport');
                const btnFull = document.getElementById('btnFullImport');
                if (btnFast && btnFull) {
                    const activeBtn = btnFull.disabled ? btnFull : btnFast;
                    activeBtn.innerHTML = `<i class="fa-solid fa-circle-notch fa-spin mr-2"></i> Importation : ${data.current}...`;
                }

                // GoodReads
                if (btnGoodreadsImport && !btnGoodreadsImport.disabled) return;
                if (btnGoodreadsImport) {
                    btnGoodreadsImport.innerHTML = `<i class="fa-solid fa-circle-notch fa-spin mr-2"></i> ${data.current} / ${data.total}`;
                }
            });

            socket.on('import_finished', (data) => {
                alert(`${data.count} <%= t('admin.modal.import_done') %>`);
                window.location.reload();
            });

            socket.on('import_error', (data) => {
                const grModal = document.getElementById('importGoodreadsModal');
                const isGrOpen = grModal && !grModal.classList.contains('hidden');
                const errorBoxId = isGrOpen ? 'goodreadsError' : 'importError';
                const errorTextId = isGrOpen ? 'goodreadsErrorText' : 'importErrorText';
                const errorBox = document.getElementById(errorBoxId);
                const errorText = document.getElementById(errorTextId);
                if (errorText) errorText.innerText = data.message;
                if (errorBox) errorBox.classList.remove('hidden');
            });

            function openImportModal(type) {
                const titleEl = document.getElementById('importModalTitle');
                const inputType = document.getElementById('importType');
                inputType.value = type;
                titleEl.innerHTML = type === 'wishlist'
                    ? '<i class="fa-solid fa-heart text-primary-theme mr-2"></i> <%= t("admin.import.wantlist") %>'
                    : '<i class="fa-solid fa-record-vinyl text-primary-theme mr-2"></i> <%= t("admin.import.collection") %>';
                toggleModal('importDiscogsModal');
            }

            async function startDiscogsImport(isFull) {
                const urlInput = document.getElementById('discogsUrl');
                const btnFast = document.getElementById('btnFastImport');
                const btnFull = document.getElementById('btnFullImport');
                const errorBox = document.getElementById('importError');
                const importType = document.getElementById('importType').value;
                if (!urlInput.value) return;
                errorBox.classList.add('hidden');
                [btnFast, btnFull].forEach(b => { b.disabled = true; b.classList.add('opacity-50'); });
                const activeBtn = isFull ? btnFull : btnFast;
                activeBtn.innerHTML = `<i class="fa-solid fa-circle-notch fa-spin mr-2"></i> <%= t('admin.modal.import_loading') %>`;
                try {
                    const response = await fetch('<%= baseUrl %>/import/discogs', {
                        method: 'POST',
                        headers: { 'Content-Type': 'application/json' },
                        body: JSON.stringify({ discogsUrl: urlInput.value, full: isFull, type: importType })
                    });
                    if (!response.ok) {
                        const data = await response.json();
                        throw new Error(data.error || "Error");
                    }
                    activeBtn.innerHTML = `<i class="fa-solid fa-spinner fa-spin mr-2"></i> <%= t('admin.modal.import_started') %>`;
                } catch (err) {
                    document.getElementById('importErrorText').innerText = err.message;
                    errorBox.classList.remove('hidden');
                    [btnFast, btnFull].forEach(b => { b.disabled = false; b.classList.remove('opacity-50'); });
                }
            }

            document.addEventListener('DOMContentLoaded', () => {
                const hasHardcoverKey = <%= locals.hasHardcoverKey || false %>;
                const hasTmdbKey = <%= locals.hasTmdbKey      || false %>;
                const hasIgdbKey = <%= locals.hasIgdbKey      || false %>;
                const modulesWithKeys = [
                    { name: 'booksActive', hasKey: hasHardcoverKey, errorId: 'error-books' },
                    { name: 'dvdActive', hasKey: hasTmdbKey, errorId: 'error-dvd' },
                    { name: 'gamesActive', hasKey: hasIgdbKey, errorId: 'error-games' }
                ];
                modulesWithKeys.forEach(mod => {
                    const checkbox = document.querySelector(`input[name="${mod.name}"]`);
                    const errorBox = document.getElementById(mod.errorId);
                    if (checkbox) {
                        checkbox.addEventListener('change', function () {
                            if (this.checked && !mod.hasKey) {
                                this.checked = false;
                                if (errorBox) {
                                    errorBox.classList.remove('hidden');
                                    setTimeout(() => errorBox.classList.add('hidden'), 5000);
                                }
                            }
                        });
                    }
                });
            });

            function interpolate(str, params) {
                return str.replace(/{{(.*?)}}/g, (_, key) => {
                    return params[key.trim()] ?? '';
                });
            }

            window.translations = {
                areyousure: <%- JSON.stringify(t('admin.areyousure')) %>,
                deleteConfirm: <%- JSON.stringify(t('admin.delete_confirm')) %>,
                refreshAllConfirm: <%- JSON.stringify(t('admin.maintenance.refresh_all_confirm')) %>,
                statusStarting: "<%= t('admin.maintenance.status_starting') %>",
                statusInit: "<%= t('admin.maintenance.status_init') %>",
                statusProcessing: "<%= t('admin.maintenance.status_processing') %>",
                statusFinished: "<%= t('admin.maintenance.status_finished') %>",
                statusError: "<%= t('admin.maintenance.status_error') %>",
                itemsUpdated: "<%= t('admin.modal.import_done') %>"
            };

            let activeRefreshKind = null;

            async function startMetadataRefresh(kind = 'Music') {
                if (!confirm(window.translations.refreshAllConfirm)) return;

                activeRefreshKind = kind;

                const mode = document.getElementById('refreshMode' + kind).value;
                const btn = document.getElementById('btnRefresh' + kind);
                const icon = document.getElementById('iconRefresh' + kind);
                const text = document.getElementById('textRefresh' + kind);
                const progressContainer = document.getElementById('progressContainer' + kind);

                btn.disabled = true;
                btn.classList.add('opacity-50', 'cursor-not-allowed');
                icon.className = 'fa-solid fa-spinner fa-spin';
                text.innerText = window.translations.statusStarting;
                progressContainer.classList.remove('hidden');

                try {
                    const url = kind === 'Book' ? '<%= baseUrl %>/admin/refresh-all-books-metadata'
                        : kind === 'Dvd' ? '<%= baseUrl %>/admin/refresh-all-dvds-metadata'
                            : kind === 'Game' ? '<%= baseUrl %>/admin/refresh-all-games-metadata'
                                : '<%= baseUrl %>/admin/refresh-all-music-metadata';

                    const response = await fetch(url, {
                        method: 'POST',
                        headers: { 'Content-Type': 'application/json' },
                        body: JSON.stringify({ mode })
                    });

                    if (!response.ok) {
                        const data = await response.json();
                        throw new Error(data.error || window.translations.statusError);
                    }
                } catch (err) {
                    alert(err.message);
                    btn.disabled = false;
                    btn.classList.remove('opacity-50', 'cursor-not-allowed');
                    icon.className = 'fa-solid fa-play';
                    text.innerText = '<%= t("admin.maintenance.refresh_all_btn") %>';
                    progressContainer.classList.add('hidden');
                    activeRefreshKind = null;
                }
            }

            socket.on('refresh_all_progress', (data) => {
                if (!activeRefreshKind) return;
                const k = activeRefreshKind;
                const percent = Math.round((data.current / data.total) * 100);
                const statusText = window.translations.statusProcessing.replace('{{current}}', data.current).replace('{{total}}', data.total);

                document.getElementById('progressBar' + k).style.width = `${percent}%`;
                document.getElementById('progressPercent' + k).innerText = `${percent}%`;
                document.getElementById('progressTitle' + k).innerText = statusText;
                document.getElementById('progressItem' + k).innerText = data.title;
                document.getElementById('textRefresh' + k).innerText = statusText;
            });

            socket.on('refresh_all_finished', (data) => {
                if (!activeRefreshKind) return;
                const k = activeRefreshKind;
                document.getElementById('progressTitle' + k).innerText = window.translations.statusFinished;
                document.getElementById('textRefresh' + k).innerText = window.translations.statusFinished;
                document.getElementById('iconRefresh' + k).className = 'fa-solid fa-check text-green-500';

                setTimeout(() => {
                    alert(`${data.count} ${window.translations.itemsUpdated}`);
                    window.location.reload();
                }, 1000);
            });

            async function confirmDeleteLast() {
                const count = parseInt(document.getElementById('deleteCount')?.value);
                const kind = document.getElementById('deleteKind')?.value;
                const kindLabel = document.getElementById('deleteKind')?.selectedOptions[0]?.text;

                if (!count || count < 1) return;

                const message = interpolate(window.translations.areyousure, {
                    count,
                    kindLabel
                });

                const confirmed = confirm(message);
                if (!confirmed) return;

                const errorBox = document.getElementById('deleteLastError');
                const errorText = document.getElementById('deleteLastErrorText');
                const successBox = document.getElementById('deleteLastSuccess');
                const successText = document.getElementById('deleteLastSuccessText');
                errorBox.classList.add('hidden');
                successBox.classList.add('hidden');

                try {
                    const response = await fetch('<%= baseUrl %>/admin/delete-last-items', {
                        method: 'POST',
                        headers: { 'Content-Type': 'application/json' },
                        body: JSON.stringify({ count, kind })
                    });
                    const data = await response.json();
                    if (!response.ok) throw new Error(data.error || 'Erreur');

                    successText.innerText = interpolate(
                        window.translations.deleteConfirm,
                        { count: data.deleted }
                    );
                    successBox.classList.remove('hidden');
                    document.getElementById('deleteCount').value = '';
                } catch (err) {
                    errorText.innerText = err.message;
                    errorBox.classList.remove('hidden');
                }
            }
        </script>
