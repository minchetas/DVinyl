<%- include('partials/header') %>

    <div
        class="fixed inset-0 -z-10 opacity-10 dark:opacity-20 blur-3xl pointer-events-none transition-opacity duration-1000">
        <img src="<%= book.cover_image %>" class="w-full h-full object-cover">
    </div>

    <div class="max-w-screen-xl mx-auto px-4 pb-20">

        <nav class="flex py-6 text-sm opacity-60 transition-colors">
            <% if (book.in_wishlist) { %>
                <a href="<%= baseUrl %>/wishlist"
                    class="hover:opacity-100 hover:text-primary-theme transition-colors flex items-center gap-2">
                    <i class="fa-solid fa-arrow-left"></i>
                    <%= t('detail.back_to_wishlist') %>
                </a>
                <% } else { %>
                    <a href="<%= baseUrl %>/collection?type=books"
                        class="hover:opacity-100 hover:text-primary-theme transition-colors flex items-center gap-2">
                        <i class="fa-solid fa-arrow-left"></i>
                        <%= t('detail.back_to_collection') %>
                    </a>
                    <% } %>
        </nav>

        <div class="grid grid-cols-1 lg:grid-cols-12 gap-8 lg:gap-12">

            <div class="lg:col-span-5 flex flex-col items-center">
                <div
                    class="relative w-full aspect-[2/3] card-theme rounded-2xl shadow-xl overflow-hidden flex items-center justify-center group transition-colors">
                    <% if(book.in_wishlist) { %>
                        <div
                            class="absolute top-4 left-4 bg-pink-500 text-white text-[10px] font-bold px-2 py-1 rounded shadow-md z-10 flex items-center gap-1">
                            <i class="fa-solid fa-gift"></i>
                            <%= t('index.section_wishlist') %>
                        </div>
                        <% } %>

                            <img id="mainImage" src="<%= book.cover_image %>"
                                class="w-full h-full object-cover transition-transform duration-300 group-hover:scale-[1.02]"
                                alt="Book Cover">

                            <span
                                class="absolute top-4 right-4 bg-white/90 dark:bg-black/60 backdrop-blur-md text-neutral-900 dark:text-white text-xs px-3 py-1 rounded-full border border-black/5 dark:border-white/10 shadow-sm">
                                <%= t('detail.official_cover') %>
                            </span>
                </div>

                <div class="w-full mt-6 grid grid-cols-2 gap-4">
                    <div class="card-theme p-4 rounded-xl text-center shadow-sm">
                        <span class="block text-[10px] uppercase font-bold opacity-50 mb-1">
                            <%= t('confirm_book.field_status') %>
                        </span>
                        <% let statusColor='text-gray-500' ; if(book.readingStatus==='reading' )
                            statusColor='text-blue-500' ; else if(book.readingStatus==='read' )
                            statusColor='text-green-500' ; %>
                            <span class="text-sm font-bold <%= statusColor %>">
                                <%= book.readingStatus==='reading' ? t('status.reading') : (book.readingStatus==='read'
                                    ? t('status.read') : t('status.to_read')) %>
                            </span>
                    </div>
                    <div class="card-theme p-4 rounded-xl text-center shadow-sm">
                        <span class="block text-[10px] uppercase font-bold opacity-50 mb-1">
                            <%= t('confirm_book.field_rating') %>
                        </span>
                        <div class="flex justify-center text-yellow-500 text-xs">
                            <% for(let i=1; i <=5; i++) { %>
                                <i
                                    class="<%= i <= book.rating ? 'fa-solid' : (i - 0.5 === book.rating ? 'fa-solid fa-star-half-stroke' : 'fa-regular') %> fa-star"></i>
                                <% } %>
                        </div>
                    </div>
                </div>
            </div>

            <div class="lg:col-span-7 space-y-8">
                <div>
                    <% if(book.series) { %>
                        <p
                            class="text-primary-theme font-bold text-sm mb-1 uppercase tracking-wider flex items-center gap-2">
                            <i class="fa-solid fa-swatchbook"></i>
                            <%= book.series %>
                                <% if(book.volume) { %> - <%= t('book_detail.volume') %>
                                        <%= book.volume %>
                                            <% } %>
                        </p>
                        <% } %>
                            <h1 class="text-3xl md:text-5xl font-black mb-2 leading-tight transition-colors">
                                <%= book.title %>
                            </h1>
                            <h2 class="text-xl md:text-2xl opacity-70 font-semibold mb-4 transition-colors">
                                <%= book.author %>
                            </h2>

                            <div class="flex flex-wrap gap-2">
                                <% const formatColors={ 'manga' : 'bg-pink-600 text-white' , 'comic'
                                    : 'bg-indigo-600 text-white' , 'hardcover' : 'bg-purple-600 text-white'
                                    , 'paperback' : 'bg-amber-600 text-white' , 'graphic_novel'
                                    : 'bg-emerald-600 text-white' }; let badgeColor=formatColors[book.format]
                                    || 'bg-gray-600 text-white' ; %>
                                    <span
                                        class="px-3 py-1 rounded-full text-xs font-bold tracking-wider <%= badgeColor %> shadow-sm">
                                        <%= t('media.' + book.format) %>
                                    </span>

                                    <% if (book.year) { %>
                                        <span
                                            class="px-3 py-1 bg-black/5 dark:bg-white/10 border border-transparent rounded-full text-xs opacity-80 transition-colors">
                                            <%= book.year %>
                                        </span>
                                        <% } %>

                                            <span
                                                class="px-3 py-1 bg-black/5 dark:bg-white/10 border border-transparent rounded-full text-xs opacity-80 transition-colors">
                                                <%= book.language ? book.language.toUpperCase() : 'N/A' %>
                                            </span>

                                            <span
                                                class="px-3 py-1 bg-black/5 dark:bg-white/10 border border-transparent rounded-full text-xs opacity-80 transition-colors">
                                                <%= t('confirm_vinyl.field_quantity') %> : <%= book.quantity || 1 %>
                                            </span>
                            </div>
                </div>

                <div class="flex flex-col gap-6 ml-2">
                    <div class="flex flex-col">
                        <span class="text-[10px] uppercase tracking-widest opacity-50 font-bold mb-2">
                            <%= t('common.location') %>
                        </span>
                        <span class="text-sm font-medium">
                            <i class="fa-solid fa-box-archive mr-2 opacity-50"></i>
                            <%= book.location || t('common.not_specified') %>
                        </span>
                    </div>

                    <% if ((book.genres && book.genres.length > 0) || (book.styles && book.styles.length > 0)) { %>
                        <div class="flex flex-col gap-4">
                            <% if (book.genres && book.genres.length > 0) { %>
                                <div class="flex flex-col">
                                    <span class="text-[10px] uppercase tracking-widest opacity-50 font-bold mb-2">
                                        <%= t('confirm_vinyl.field_genres') %>
                                    </span>
                                    <div class="flex flex-wrap gap-2">
                                        <% book.genres.forEach(genre => { %>
                                            <span
                                                class="px-2 py-0.5 bg-black/5 dark:bg-white/5 border border-black/10 dark:border-white/10 rounded-md text-[11px] font-medium transition-colors hover:bg-primary-theme/10 hover:border-primary-theme/30 cursor-default">
                                                <%= genre %>
                                            </span>
                                        <% }) %>
                                    </div>
                                </div>
                            <% } %>

                            <% if (book.styles && book.styles.length > 0) { %>
                                <div class="flex flex-col">
                                    <span class="text-[10px] uppercase tracking-widest opacity-50 font-bold mb-2">
                                        <%= t('confirm_vinyl.field_styles') %>
                                    </span>
                                    <div class="flex flex-wrap gap-2">
                                        <% book.styles.forEach(style => { %>
                                            <span
                                                class="px-2 py-0.5 bg-primary-theme/5 border border-primary-theme/10 text-primary-theme/80 rounded-md text-[11px] font-medium transition-colors hover:bg-primary-theme/10 hover:border-primary-theme/30 cursor-default">
                                                <%= style %>
                                            </span>
                                        <% }) %>
                                    </div>
                                </div>
                            <% } %>
                        </div>
                    <% } else { %>
                        <div class="flex flex-col">
                            <span class="text-[10px] uppercase tracking-widest opacity-50 font-bold mb-1">
                                Genre
                            </span>
                            <span class="text-sm font-medium">
                                <i class="fa-solid fa-book-open mr-2 opacity-50"></i>
                                <%= book.genre || t('common.not_specified') %>
                            </span>
                        </div>
                    <% } %>
                </div>

                <div class="card-theme rounded-xl p-6 grid grid-cols-2 gap-y-6 gap-x-4 transition-colors shadow-sm">
                    <div>
                        <span class="block text-xs opacity-50 uppercase font-bold mb-1">
                            <%= t('confirm_book.field_publisher') %>
                        </span>
                        <span class="font-medium transition-colors">
                            <%= book.publisher || 'N/A' %>
                        </span>
                    </div>
                    <div>
                        <span class="block text-xs opacity-50 uppercase font-bold mb-1">ISBN</span>
                        <span class="font-mono text-sm bg-black/5 dark:bg-white/5 px-2 py-1 rounded transition-colors">
                            <%= book.isbn || 'N/A' %>
                        </span>
                    </div>
                    <div>
                        <span class="block text-xs opacity-50 uppercase font-bold mb-1">
                            <%= t('confirm_book.field_pages') %>
                        </span>
                        <span class="transition-colors">
                            <%= book.pages ? book.pages + ' p.' : 'N/A' %>
                        </span>
                    </div>
                    <div>
                        <span class="block text-xs opacity-50 uppercase font-bold mb-1">
                            <%= t('detail.added_at') %>
                        </span>
                        <span class="transition-colors">
                            <%= new Date(book.added_at).toLocaleDateString(currentLng==='fr' ? 'fr-FR' : 'en-US' ) %>
                        </span>
                    </div>
                    <div class="col-span-2 border-t border-black/10 dark:border-white/10 mt-2 pt-4 transition-colors">
                        <span class="block text-xs opacity-50 uppercase font-bold mb-1">
                            <%= t('detail.source') %>
                        </span>
                        <% if (book.source==='hardcover' && book.hardcover_slug) { %>
                            <a href="https://hardcover.app/books/<%= book.hardcover_slug %>" target="_blank"
                                class="text-primary-theme hover:underline text-sm inline-flex items-center gap-1">
                                <i class="fa-solid fa-book"></i>
                                <%= t('book.source_hardcover') %>
                            </a>
                            <% } else if (book.source==='goodreads' ) { %>
                                <a href="https://www.goodreads.com/search?q=<%= encodeURIComponent(book.isbn || book.title) %>"
                                    target="_blank"
                                    class="text-[#553B08] dark:text-yellow-600 hover:underline text-sm inline-flex items-center gap-1">
                                    <i class="fa-solid fa-book-open"></i>
                                    <%= t('book.source_goodreads') %>
                                </a>
                                <% } %>
                    </div>
                </div>

                <% if (book.comments) { %>
                    <div
                        class="card-theme rounded-xl p-6 border border-black/10 dark:border-white/10 relative overflow-hidden shadow-sm transition-colors">
                        <div class="absolute -right-2 -top-2 text-black/5 dark:text-white/5 text-6xl">
                            <i class="fa-solid fa-quote-right"></i>
                        </div>
                        <h3 class="text-xs uppercase font-bold opacity-50 mb-3 flex items-center gap-2 relative z-10">
                            <i class="fa-regular fa-comment-dots"></i>
                            <%= t('detail.personal_notes') %>
                        </h3>
                        <p class="text-sm leading-relaxed whitespace-pre-line relative z-10 transition-colors">
                            <%= book.comments %>
                        </p>
                    </div>
                    <% } %>

                        <% if (user.isAdmin) { %>
                            <div
                                class="pt-6 border-t border-black/10 dark:border-white/10 flex justify-end gap-4 transition-colors">
                                <div class="flex-1 flex gap-2">
                                    <% if (book.source === 'hardcover' && book.hardcover_slug) { %>
                                        <button id="refreshInfoBtn"
                                            onclick="refreshMetadata('<%= book._id %>')"
                                            class="opacity-60 hover:opacity-100 px-4 py-2 text-sm transition-colors border border-black/10 dark:border-white/10 rounded-lg hover:bg-black/5 dark:hover:bg-white/5 flex items-center gap-2">
                                            <i class="fa-solid fa-arrows-rotate" id="refreshInfoIcon"></i>
                                            <%= t('collection.refresh_metadata_btn') %>
                                        </button>
                                    <% } %>
                                </div>
                                <a href="<%= baseUrl %>/book/edit/<%= book._id %>"
                                    class="opacity-70 hover:opacity-100 hover:text-primary-theme px-4 py-2 text-sm transition-colors border border-black/10 dark:border-white/10 rounded-lg hover:bg-black/5 dark:hover:bg-white/5">
                                    <i class="fa-solid fa-pen-to-square mr-2"></i>
                                    <%= t('common.edit') %>
                                </a>
                                <button onclick="confirmDelete('<%= book._id %>')"
                                    class="text-red-600 dark:text-red-500 hover:text-red-700 dark:hover:text-red-400 bg-red-100 dark:bg-red-500/10 hover:bg-red-200 dark:hover:bg-red-500/20 px-4 py-2 rounded-lg text-sm transition-colors">
                                    <i class="fa-solid fa-trash mr-2"></i>
                                    <%= t('admin.tooltips.delete') %>
                                </button>
                            </div>
                            <% } %>
            </div>
        </div>
    </div>

    <script>
        const translations = {
            official_cover: "<%= t('detail.official_cover') %>",
            additional_image: "<%= t('detail.additional_image') %>",
            confirm_delete: "<%= t('detail.confirm_delete') %>",
            unavailable_data: "<%= t('detail.unavailable_data') %>",
            error_server: "<%= t('messages.generic_error') %>"
        };

        async function confirmDelete(id) {
            if (confirm(translations.confirm_delete)) {
                try {
                    const response = await fetch(`<%= baseUrl %>/api/book/${id}`, {
                        method: 'DELETE',
                        headers: { 'Content-Type': 'application/json' }
                    });

                    const data = await response.json();
                    if (data.success) {
                        window.location.href = '<%= baseUrl %>' + data.redirectUrl;
                    } else {
                        alert(`${translations.error_server}: ${data.error}`);
                    }
                } catch (err) {
                    console.error(err);
                    alert(translations.error_server);
                }
            }
        }

        async function refreshMetadata(bookId) {
            const btn = document.getElementById('refreshInfoBtn');
            const icon = document.getElementById('refreshInfoIcon');

            btn.disabled = true;
            icon.classList.add('fa-spin');

            try {
                const response = await fetch(`<%= baseUrl %>/api/book/${bookId}/refresh-info`, {
                    method: 'POST',
                    headers: { 'Content-Type': 'application/json' }
                });

                const data = await response.json();

                if (response.ok && data.success) {
                    window.location.reload();
                } else {
                    alert("<%= t('detail.refresh_info_error') || 'Refresh failed' %>");
                    btn.disabled = false;
                    icon.classList.remove('fa-spin');
                }
            } catch (err) {
                console.error(err);
                alert("<%= t('detail.refresh_info_error') || 'Refresh failed' %>");
                btn.disabled = false;
                icon.classList.remove('fa-spin');
            }
        }
    </script>
