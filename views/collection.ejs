<%- include('partials/header') %>

<div class="max-w-screen-xl mx-auto px-4 md:px-0 pb-12">
    
    <div class="pt-6 mb-6">
        <h1 class="text-3xl font-bold transition-colors">
            <%= t('collection.title') %>
        </h1>
    </div>

    <div class="space-y-6 mb-8">
                        
        <div class="flex flex-wrap gap-2 mb-8" id="formatFilters">
            <% 
            const mainTypes = [
                { id: 'all', label: t('common.all') },
                { id: 'music', label: t('media.music') },
                { id: 'books', label: t('media.books') },
                { id: 'dvd', label: t('media.dvds') }
            ];
            %>

            <% if (currentType === 'all') { %>
                <% mainTypes.forEach(type => { %>
                    <button onclick="updateURLParams('type', '<%= type.id %>')" 
                        class="px-4 py-2 rounded-full text-xs font-bold transition-all active:scale-95 <%= currentType === type.id ? 'bg-primary-theme text-white shadow-lg' : 'bg-black/5 dark:bg-white/10 opacity-60' %>">
                        <%= type.label %>
                    </button>
                <% }) %>
            <% } else { %>
                <button onclick="updateURLParams('type', 'all')" 
                    class="px-4 py-2 rounded-full text-xs font-bold transition-all active:scale-95 bg-black/5 dark:bg-white/10 opacity-60">
                    <i class="fa-solid fa-arrow-left mr-2"></i> <%= t('common.all') %>
                </button>

                <% activeFilters.forEach(filter => { %>
                    <button onclick="updateURLParams('format', '<%= filter.id %>')" 
                        class="px-4 py-2 rounded-full text-xs font-bold transition-all active:scale-95 <%= currentFormat === filter.id ? 'bg-primary-theme text-white shadow-lg' : 'bg-black/5 dark:bg-white/10 opacity-60' %>">
                        <%= filter.label %>
                    </button>
                <% }) %>
            <% } %>
        </div>

        <div class="flex flex-col md:flex-row gap-3">
            <div class="relative flex-grow">
                <div class="absolute inset-y-0 left-0 flex items-center pl-3 pointer-events-none">
                    <i class="fa-solid fa-search opacity-50"></i>
                </div>
                <input type="text" id="filterInput" class="block w-full p-2.5 pl-10 text-sm card-theme rounded-lg border focus:ring-1 focus:ring-primary-theme placeholder-opacity-50" value="<%= locals.querySearch || '' %>" placeholder="<%= t('collection.filter_placeholder') %>">
            </div>

            <div class="w-full md:w-48">
                <input type="text" id="locationInput" list="locations-list" placeholder="<%= t('common.location') %>" class="block w-full p-2.5 text-sm card-theme rounded-lg border focus:ring-1 focus:ring-primary-theme outline-none placeholder-opacity-50">
                <datalist id="locations-list">
                    <% locations.forEach(loc => { %> <option value="<%= loc %>"></option> <% }) %>
                </datalist>
            </div>

            <% if (user.isAdmin && currentType === 'music') { %>
                <div class="flex gap-2">
                    <button onclick="openEstimateModal()" 
                        class="flex-shrink-0 w-10 h-10 md:w-auto md:px-4 card-theme hover:text-primary-theme hover:border-primary-theme rounded-lg transition-all shadow-sm flex items-center justify-center gap-2 group" 
                        title="<%= t('index.btn_estimate') %>">
                        <i class="fa-solid fa-calculator group-hover:scale-110 transition-transform"></i>
                        <span class="hidden md:inline text-xs font-bold uppercase tracking-widest"><%= t('index.btn_estimate') %></span>
                    </button>

                    <% if (user.discogsUsername) { %>
                        <button onclick="refreshCollection()" id="refreshBtn" 
                            class="flex-shrink-0 w-10 h-10 md:w-auto md:px-4 card-theme hover:text-primary-theme hover:border-primary-theme rounded-lg transition-all shadow-sm flex items-center justify-center gap-2 group" 
                            title="<%= t('collection.refresh_tooltip') %>">
                            <i class="fa-solid fa-sync group-hover:rotate-180 transition-transform duration-500"></i>
                            <span class="hidden md:inline text-xs font-bold uppercase tracking-widest">
                                <%= t('collection.refresh') %>
                            </span>
                        </button>
                    <% } %>
                </div>
            <% } else if (user.isAdmin && user.discogsUsername) { %>
                <div class="flex gap-2">
                    <button onclick="refreshCollection()" id="refreshBtn" 
                        class="flex-shrink-0 w-10 h-10 md:w-auto md:px-4 card-theme hover:text-primary-theme hover:border-primary-theme rounded-lg transition-all shadow-sm flex items-center justify-center gap-2 group">
                        <i class="fa-solid fa-sync group-hover:rotate-180 transition-transform duration-500"></i>
                        <span class="hidden md:inline text-xs font-bold uppercase tracking-widest"><%= t('collection.refresh') %></span>
                    </button>
                </div>
            <% } %>
        </div>
    </div>

    <div class="grid grid-cols-2 sm:grid-cols-3 md:grid-cols-4 lg:grid-cols-5 gap-6" id="albumGrid">
        <% albums.forEach(album => { %>
            <% 
                const isBook = album.kind === 'Book';
                const isDvd = album.kind === 'Dvd' || (album.tmdb_id !== undefined && album.tmdb_id !== null);
                
                const aspectClass = 'aspect-square'; 

                let detailUrl = `/album/${album._id}`;
                if (isBook) detailUrl = `/book/${album._id}`;
                if (isDvd) detailUrl = `/dvd/${album._id}`;

                const formatKey = (isDvd) ? album.format : (album.media_type || album.format);

                const badgeMap = {
                        'vinyl': 'bg-green-600/90', 'cd': 'bg-blue-600/90', 'cassette': 'bg-orange-600/90',
                        'manga': 'bg-pink-600/90', 'comic': 'bg-indigo-600/90', 'hardcover': 'bg-purple-600/90',
                        'paperback': 'bg-amber-600/90', 'book': 'bg-amber-700/90',
                        'dvd': 'bg-sky-600/90', 'bluray': 'bg-indigo-700/90', '4k': 'bg-red-600/90',
                        'vhs': 'bg-amber-600/90', 'laserdisc': 'bg-purple-600/90'
                    };

                let badgeClass = badgeMap[formatKey] || 'bg-gray-600/90';
            %>
            
            <div class="album-card group relative card-theme rounded-xl overflow-hidden hover:border-primary-theme transition-all duration-300 hover:shadow-lg hover:-translate-y-1" 
                data-location="<%= album.location || '' %>" 
                data-format="<%= isDvd ? album.format : (album.media_type || album.format || '') %>">
                <a href="<%= detailUrl %>" class="block">
                    <div class="<%= aspectClass %> w-full relative overflow-hidden bg-black/5 flex items-center justify-center">
    
                        <% if (isBook || isDvd) { %>
                            <img src="<%= album.cover_image %>" 
                                class="absolute inset-0 w-full h-full object-cover blur-xl opacity-30 scale-110 pointer-events-none">
                        <% } %>

                        <img src="<%= album.cover_image %>" 
                            class="relative z-10 w-full h-full <%= (isBook || isDvd) ? 'object-contain p-2' : 'object-cover' %> transition-transform duration-500 group-hover:scale-105" 
                            loading="lazy">
                        
                        <span class="absolute bottom-2 left-2 z-20 text-white text-[10px] font-bold px-2 py-1 rounded backdrop-blur-md border border-white/10 shadow-sm <%= badgeClass %>">
                            <%= t('media.' + formatKey) %>
                        </span>
                    </div>

                    <div class="p-3">
                        <h3 class="font-bold text-sm truncate" title="<%= album.title %>"><%= album.title %></h3>
                        <p class="text-xs opacity-60 truncate mb-2">
                            <%= isBook ? album.author : (album.artist || album.director || 'Inconnu') %>
                        </p>
                        
                        <% if(album.variant_color) { %>
                            <div class="flex items-center gap-1">
                                <span class="w-2 h-2 rounded-full bg-primary-theme inline-block flex-shrink-0"></span>
                                <span class="text-[10px] opacity-60 truncate max-w-full"><%= album.variant_color %></span>
                            </div>
                        <% } %>
                    </div>
                </a>
            </div>
        <% }) %>
    </div>

    <div class="mt-12 flex flex-col md:flex-row items-center justify-between gap-6 border-t border-black/5 dark:border-white/10 pt-8">
        
        <div class="flex items-center gap-3 order-2 md:order-1">
            <span class="text-xs font-bold uppercase tracking-widest opacity-40"><%= t('common.show') %></span>
            <div class="flex bg-black/5 dark:bg-white/5 p-1 rounded-xl">
                <% [25, 50, 100].forEach(num => { %>
                    <button onclick="changeLimit(<%= num %>)" 
                        class="px-3 py-1.5 text-xs font-bold rounded-lg transition-all <%= (locals.queryLimit == num) ? 'bg-primary-theme text-white shadow-md' : 'opacity-50 hover:opacity-100' %>">
                        <%= num %>
                    </button>
                <% }) %>
            </div>
        </div>

        <% if (totalPages > 1) { %>
        <nav class="flex items-center gap-2 order-1 md:order-2">
            <button onclick="changePage(<%= currentPage - 1 %>)" 
                <%= currentPage <= 1 ? 'disabled' : '' %>
                class="w-10 h-10 flex items-center justify-center rounded-xl card-theme border-none hover:bg-primary-theme hover:text-white transition-all disabled:opacity-20 disabled:pointer-events-none">
                <i class="fa-solid fa-chevron-left text-xs"></i>
            </button>

            <div class="flex items-center gap-1">
                <% for(let i = 1; i <= totalPages; i++) { 
                    if (i === 1 || i === totalPages || (i >= currentPage - 1 && i <= currentPage + 1)) { %>
                        <button onclick="changePage(<%= i %>)" 
                            class="w-10 h-10 flex items-center justify-center rounded-xl font-bold text-sm transition-all <%= currentPage === i ? 'bg-primary-theme text-white shadow-lg scale-110' : 'card-theme hover:bg-black/5 dark:hover:bg-white/5' %>">
                            <%= i %>
                        </button>
                    <% } else if (i === currentPage - 2 || i === currentPage + 2) { %>
                        <span class="px-1 opacity-30">...</span>
                    <% }
                } %>
            </div>

            <button onclick="changePage(<%= currentPage + 1 %>)" 
                <%= currentPage >= totalPages ? 'disabled' : '' %>
                class="w-10 h-10 flex items-center justify-center rounded-xl card-theme border-none hover:bg-primary-theme hover:text-white transition-all disabled:opacity-20 disabled:pointer-events-none">
                <i class="fa-solid fa-chevron-right text-xs"></i>
            </button>
        </nav>
        <% } %>
    </div>
</div>

<div id="estimateModal" class="fixed inset-0 z-50 hidden bg-black/80 backdrop-blur-sm flex items-center justify-center p-4">
    <div class="card-theme rounded-2xl w-full max-w-lg p-6 md:p-8 shadow-2xl relative">
        <button onclick="closeEstimateModal()" class="absolute top-4 right-4 opacity-50 hover:opacity-100">
            <i class="fa-solid fa-xmark text-xl"></i>
        </button>

        <h3 class="text-2xl font-bold mb-2"><%= t('modal.estimate_title') %></h3>
        <p class="opacity-60 text-sm mb-6"><%= t('modal.estimate_desc') %></p>

        <div id="progressContainer" class="mb-6">
            <div class="w-full bg-gray-200 dark:bg-black/30 rounded-full h-4 mb-2 overflow-hidden">
                <div id="estimateProgress" class="bg-primary-theme h-4 rounded-full transition-all duration-300" style="width: 0%"></div>
            </div>
            <div class="flex justify-between text-xs opacity-60 font-mono">
                <span id="estimateCount">0 / --</span> 
                <span id="estimatePercent">0%</span>
            </div>
        </div>

        <div id="estimateResult" class="hidden text-center space-y-4">
            <div class="p-6 bg-primary-theme/10 border border-primary-theme/30 rounded-xl">
                <p class="text-primary-theme text-sm font-bold uppercase tracking-wider mb-1"><%= t('modal.avg_label') %></p>
                <h4 id="finalPrice" class="text-4xl md:text-5xl font-black">--</h4>
                <p class="text-xs opacity-60 mt-2"><%= t('modal.condition_hint') %></p>
            </div>
            <div class="grid grid-cols-2 gap-4">
                <div class="bg-gray-100 dark:bg-black/20 p-3 rounded-lg">
                    <span class="opacity-60 block text-[10px] uppercase font-bold"><%= t('modal.min_label') %></span>
                    <span id="minPrice" class="font-bold text-lg">--</span>
                </div>
                <div class="bg-gray-100 dark:bg-black/20 p-3 rounded-lg">
                    <span class="opacity-60 block text-[10px] uppercase font-bold"><%= t('modal.max_label') %></span>
                    <span id="maxPrice" class="font-bold text-lg">--</span>
                </div>
            </div>
        </div>

        <div id="startEstimateBtn" class="mt-6 text-center">
            <button onclick="startEstimation()" class="bg-primary-theme hover:brightness-110 text-white font-bold py-3 px-8 rounded-xl transition-colors">
                <%= t('modal.start_btn') %>
            </button>
        </div>
    </div>
</div>

<script src="/socket.io/socket.io.js"></script>
<script>
    const filterInput = document.getElementById('filterInput');
    const locationInput = document.getElementById('locationInput');
    let searchTimeout;

    function updateURLParams(key, value) {
        const url = new URL(window.location.href);
        
        if (value === 'all' || !value) {
            url.searchParams.delete(key);
            if (key === 'type') url.searchParams.delete('format');
        } else {
            url.searchParams.set(key, value);
        }

        url.searchParams.set('page', 1);
        window.location.href = url.toString();
    }

    function changeLimit(val) {
        updateURLParams('limit', val);
    }

    function changePage(page) {
        const url = new URL(window.location.href);
        url.searchParams.set('page', page);
        window.location.href = url.toString();
    }

    if (filterInput) {
        filterInput.addEventListener('input', (e) => {
            clearTimeout(searchTimeout);
            searchTimeout = setTimeout(() => {
                updateURLParams('search', e.target.value);
            }, 500);
        });
    }

    if (locationInput) {
        locationInput.addEventListener('change', (e) => {
            updateURLParams('location', e.target.value);
        });
    }

    <% if (user.isAdmin) { %>
        const socket = io();
        async function refreshCollection() {
            const btn = document.getElementById('refreshBtn');
            const icon = btn.querySelector('i');
            icon.classList.add('fa-spin');
            btn.disabled = true;
            
            socket.once('import_finished', () => window.location.reload());
            socket.once('import_error', (data) => {
                alert("Erreur : " + data.message);
                icon.classList.remove('fa-spin');
                btn.disabled = false;
            });

            try {
                const isWishlist = window.location.pathname.includes('wishlist');
                await fetch('/import/discogs', {
                    method: 'POST',
                    headers: { 'Content-Type': 'application/json' },
                    body: JSON.stringify({
                        discogsUrl: `https://www.discogs.com/user/<%= user.discogsUsername %>`,
                        full: false,
                        type: isWishlist ? 'wishlist' : 'collection'
                    })
                });
            } catch (e) {
                icon.classList.remove('fa-spin');
                btn.disabled = false;
            }
        }
    <% } %>

    const modal = document.getElementById('estimateModal');
    const startBtn = document.getElementById('startEstimateBtn');
    const resultDiv = document.getElementById('estimateResult');
    const progressBar = document.getElementById('estimateProgress');
    const countSpan = document.getElementById('estimateCount');
    const percentSpan = document.getElementById('estimatePercent');
    const estimateErrorMsg = "<%= t('messages.estimate_error') %>";
    const currentLocale = '<%= currentLng === "fr" ? "fr-FR" : "en-US" %>';
    const currentCurrency = '<%= user.currency || "USD" %>';

    let totalAlbums = 0;
    let currentProcessed = 0;
    let totalPriceVG = 0;
    let totalPriceMin = 0;
    let totalPriceMax = 0;

    function openEstimateModal() {
        modal.classList.remove('hidden');
    }

    function closeEstimateModal() {
        modal.classList.add('hidden');
    }

  async function startEstimation() {
        startBtn.classList.add('hidden');
        try {
            const res = await fetch('/api/collection/ids?type=music'); 
            const data = await res.json();
            
            if(!data.success) throw new Error("Server Error");
            
            const albumsToEstimate = data.albums;
            totalAlbums = albumsToEstimate.length;
            currentProcessed = 0;
            totalPriceVG = 0;
            totalPriceMin = 0;
            totalPriceMax = 0;

            countSpan.innerText = `0 / ${totalAlbums}`; 

            for (const album of albumsToEstimate) {
                await estimateOneAlbum(album.discogs_id, album.quantity || 1);
                currentProcessed++;                

                const percent = Math.round((currentProcessed / totalAlbums) * 100);
                if (progressBar) progressBar.style.width = percent + '%';
                if (percentSpan) percentSpan.innerText = percent + '%';
                
                if (countSpan) countSpan.innerText = `${currentProcessed} / ${totalAlbums}`;

                await new Promise(r => setTimeout(r, 500));
            }
            showResults();
        } catch (err) {
            alert(`${estimateErrorMsg} : ${err.message}`);
            startBtn.classList.remove('hidden');
        }
    }

    async function estimateOneAlbum(id, quantity) {
        try {
            const res = await fetch(`/api/estimate/${id}`);
            const data = await res.json();
            if (data.success && data.price) {
                const val = data.price.value * quantity;
                totalPriceVG += val;
                totalPriceMin += val; 
                totalPriceMax += (val * 1.3);
            }
        } catch (e) {}
    }

    function showResults() {
    const fmt = (val) => {
        try {
            return new Intl.NumberFormat(currentLocale, { 
                style: 'currency', 
                currency: currentCurrency 
            }).format(val);
        } catch (e) {
            return val.toFixed(2) + ' ' + currentCurrency;
        }
    };

        document.getElementById('finalPrice').innerText = fmt(totalPriceVG);
        document.getElementById('minPrice').innerText = fmt(totalPriceMin);
        document.getElementById('maxPrice').innerText = fmt(totalPriceMax);

        document.getElementById('progressContainer').classList.add('hidden');
        resultDiv.classList.remove('hidden');
    }
</script>

<%- include('partials/footer') %>