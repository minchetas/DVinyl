<%- include('partials/header') %>

<div class="max-w-screen-xl mx-auto pb-20 px-4 md:px-0">
    <nav class="flex mb-6 text-sm opacity-60 transition-colors">
        <a href="<%= baseUrl %>/add-vinyl" class="hover:opacity-100 transition-opacity flex items-center py-2">
            <i class="fa-solid fa-arrow-left mr-2"></i> <%= t('common.back_to_search') %>
        </a>
    </nav>

    <div class="grid grid-cols-1 lg:grid-cols-12 gap-8">
        <div class="lg:col-span-4 space-y-6">
            <div class="card-theme rounded-xl p-6 sticky top-24 transition-colors shadow-sm">
                <div class="aspect-square rounded-lg overflow-hidden mb-4 shadow-lg relative group bg-black/5 dark:bg-white/5">
                    <img id="livePreview" src="<%= vinyl.cover_image %>" class="w-full h-full object-cover transition-all duration-500">
                    <div class="absolute inset-0 bg-black/40 hidden group-hover:flex items-center justify-center text-white text-xs font-bold backdrop-blur-sm">
                        <%= t('confirm_vinyl.cover_preview') %>
                    </div>
                </div>
                
                <h2 class="text-xl font-bold mb-1 leading-tight"><%= vinyl.title %></h2>
                <p class="opacity-60 mb-4"><%= vinyl.artist %></p>

                <div class="space-y-3 text-sm border-t border-black/10 dark:border-white/10 pt-4 transition-colors">
                    <div class="flex justify-between">
                        <span class="opacity-60"><%= t('confirm_vinyl.label_label') %></span>
                        <span class="font-medium text-right"><%= vinyl.label %></span>
                    </div>
                    <div class="flex justify-between">
                        <span class="opacity-60"><%= t('confirm_vinyl.catalog_label') %></span>
                        <span class="font-mono opacity-80"><%= vinyl.catalog_number %></span>
                    </div>
                    <div class="flex justify-between">
                        <span class="opacity-60"><%= t('confirm_vinyl.year_label') %></span>
                        <span><%= vinyl.year %></span>
                    </div>
                    <div class="flex justify-between">
                        <span class="opacity-60"><%= t('confirm_vinyl.country') %></span>
                        <span class="font-medium"><%= vinyl.country %></span>
                    </div>
                </div>

                <% if(vinyl.tracklist && vinyl.tracklist.length > 0) { %>
                    <div class="mt-6 border-t border-black/10 dark:border-white/10 pt-4 transition-colors">
                        <h3 class="text-xs uppercase font-bold opacity-50 mb-3"><%= t('confirm_vinyl.tracks_title') %></h3>
                        <ul class="text-sm space-y-2 max-h-60 overflow-y-auto pr-2 custom-scrollbar">
                            <% vinyl.tracklist.forEach(track => { %>
                                <li class="flex gap-3 opacity-70 hover:opacity-100 transition-opacity">
                                    <span class="font-mono opacity-50 w-6 text-right flex-shrink-0"><%= track.position %></span>
                                    <span class="truncate"><%= track.title %></span>
                                    <% if(track.duration) { %>
                                        <span class="ml-auto text-xs opacity-50"><%= track.duration %></span>
                                    <% } %>
                                </li>
                            <% }) %>
                        </ul>
                    </div>
                <% } %>
            </div>
        </div>

        <div class="lg:col-span-8">
            <div class="card-theme rounded-xl p-6 md:p-8 transition-colors shadow-sm">
                <h1 class="text-2xl font-bold mb-6 flex items-center gap-2">
                    <i class="fa-solid fa-pen-to-square text-primary-theme"></i> <%= t('confirm_vinyl.config_title') %>
                </h1>

                <form action="<%= baseUrl %>/save-vinyl" method="POST" class="space-y-6">
                    <div class="grid grid-cols-1 md:grid-cols-2 gap-6">
                        <div>
                            <label class="block mb-2 text-sm font-bold uppercase tracking-widest opacity-60"><%= t('confirm_vinyl.field_title') %></label>
                            <input type="text" name="title" value="<%= vinyl.title %>" class="bg-black/5 dark:bg-white/5 border border-transparent rounded-lg text-sm focus:ring-primary-theme focus:border-primary-theme block w-full p-3 transition-colors outline-none">
                        </div>
                        <div>
                            <label class="block mb-2 text-sm font-bold uppercase tracking-widest opacity-60"><%= t('confirm_vinyl.field_artist') %></label>
                            <input type="text" name="artist" value="<%= vinyl.artist %>" class="bg-black/5 dark:bg-white/5 border border-transparent rounded-lg text-sm focus:ring-primary-theme focus:border-primary-theme block w-full p-3 transition-colors outline-none">
                        </div>
                    </div>

                    <div class="grid grid-cols-1 md:grid-cols-2 gap-6">
                        <div>
                            <label class="block mb-2 text-sm font-bold uppercase tracking-widest opacity-60"><%= t('confirm_vinyl.field_format') %></label>
                            <input type="text" name="format_type" value="<%= vinyl.format_type %>" class="bg-black/5 dark:bg-white/5 border border-transparent rounded-lg text-sm focus:ring-primary-theme focus:border-primary-theme block w-full p-3 transition-colors outline-none">
                        </div>
                        <div>
                            <label class="block mb-2 text-sm font-bold uppercase tracking-widest text-primary-theme"><%= t('confirm_vinyl.field_edition') %></label>
                            <input type="text" name="variant_color" value="<%= vinyl.variant_color %>" class="bg-black/5 dark:bg-white/5 border border-primary-theme/30 text-sm rounded-lg focus:ring-primary-theme block w-full p-3 placeholder-opacity-50 transition-colors outline-none" placeholder="<%= t('confirm_vinyl.edition_placeholder') %>">
                        </div>
                    </div>

                    <div class="w-full md:w-1/2">
                        <label class="block mb-2 text-sm font-bold uppercase tracking-widest opacity-60"><%= t('confirm_vinyl.field_quantity') %></label>
                        <input type="number" name="quantity" value="1" min="1" class="bg-black/5 dark:bg-white/5 border border-transparent rounded-lg text-sm focus:ring-primary-theme focus:border-primary-theme block w-full p-3 transition-colors outline-none">
                    </div>

                    <hr class="border-black/10 dark:border-white/10 my-6 transition-colors">

                    <div class="space-y-4">
                        <div class="flex items-center">
                            <input id="checkEditCover" type="checkbox" class="w-4 h-4 text-primary-theme bg-black/5 dark:bg-white/10 border-transparent rounded focus:ring-primary-theme focus:ring-2 cursor-pointer transition-colors">
                            <label for="checkEditCover" class="ml-2 text-sm font-bold cursor-pointer opacity-80 hover:opacity-100 transition-opacity">
                                <%= t('confirm_vinyl.replace_cover') %>
                            </label>
                        </div>

                        <input type="hidden" name="cover_image" id="inputCoverImage" value="<%= vinyl.cover_image %>">

                        <div id="boxEditCover" class="hidden p-4 card-theme rounded-2xl border border-black/10 dark:border-white/10 shadow-inner transition-all">
                            <div class="flex gap-1 mb-6 p-1 bg-black/5 dark:bg-white/5 rounded-xl">
                                <button type="button" onclick="setImgTab('cover', 'local')" id="tab-cover-local" class="flex-1 py-2 text-[10px] font-black uppercase tracking-widest rounded-lg transition-all bg-primary-theme text-white">
                                    <i class="fa-solid fa-upload mr-1"></i> <%= t('confirm_vinyl.source_local') %>
                                </button>
                                <button type="button" onclick="setImgTab('cover', 'url')" id="tab-cover-url" class="flex-1 py-2 text-[10px] font-black uppercase tracking-widest rounded-lg transition-all opacity-50">
                                    <i class="fa-solid fa-link mr-1"></i> <%= t('confirm_vinyl.source_url') %>
                                </button>
                                <button type="button" onclick="setImgTab('cover', 'search')" id="tab-cover-search" class="flex-1 py-2 text-[10px] font-black uppercase tracking-widest rounded-lg transition-all opacity-50">
                                    <i class="fa-solid fa-search mr-1"></i> <%= t('confirm_vinyl.source_search') %>
                                </button>
                            </div>

                            <div id="pane-cover-local" class="img-pane-cover">
                                <label class="flex flex-col items-center justify-center w-full h-32 border-2 border-dashed border-black/10 dark:border-white/10 rounded-2xl cursor-pointer hover:bg-black/5 transition-all">
                                    <i class="fa-solid fa-cloud-arrow-up text-2xl opacity-20 mb-2"></i>
                                    <p class="text-xs font-bold opacity-50 italic"><%= t('confirm_vinyl.browse_files') %></p>
                                    <input type="file" id="fileInputCover" class="hidden" accept="image/*">
                                </label>
                            </div>

                            <div id="pane-cover-url" class="img-pane-cover hidden">
                                <input type="url" id="urlInputCover" placeholder="https://site.com/image.jpg" class="w-full bg-white dark:bg-black/20 border-transparent rounded-lg p-3 text-sm outline-none focus:ring-2 focus:ring-primary-theme">
                            </div>

                            <div id="pane-cover-search" class="img-pane-cover hidden">
                                <div class="flex gap-2 mb-4">
                                    <input type="text" id="queryCover" value="<%= vinyl.artist %> <%= vinyl.title %>" class="flex-grow bg-white dark:bg-black/20 border-transparent rounded-lg p-2 text-sm outline-none focus:ring-2 focus:ring-primary-theme">
                                    <button type="button" onclick="runUniversalSearch('cover')" class="bg-primary-theme text-white px-4 rounded-lg hover:brightness-110"><i class="fa-solid fa-search"></i></button>
                                </div>
                                <div id="resultsCover" class="grid grid-cols-3 gap-3 max-h-60 overflow-y-auto custom-scrollbar p-1"></div>
                            </div>
                        </div> </div>

                    <div class="mt-8 space-y-4">
                        <div class="flex items-center">
                            <input id="checkEditDisc" type="checkbox" <%= vinyl.user_image ? 'checked' : '' %> class="w-4 h-4 text-primary-theme bg-black/5 dark:bg-white/10 border-transparent rounded focus:ring-primary-theme focus:ring-2 cursor-pointer transition-colors">
                            <label for="checkEditDisc" class="ml-2 text-sm font-bold cursor-pointer opacity-80 hover:opacity-100 transition-opacity">
                                <%= t('confirm_vinyl.add_secondary_visual') %>
                            </label>
                        </div>

                        <input type="hidden" name="user_image" id="inputUserImage" value="<%= vinyl.user_image %>">

                        <div id="boxEditDisc" class="hidden p-4 card-theme rounded-2xl border border-primary-theme/30 shadow-inner transition-all">
                            <div class="flex gap-1 mb-6 p-1 bg-black/5 dark:bg-white/5 rounded-xl">
                                <button type="button" onclick="setImgTab('disc', 'local')" id="tab-disc-local" class="flex-1 py-2 text-[10px] font-black uppercase tracking-widest rounded-lg transition-all bg-primary-theme text-white">
                                    <i class="fa-solid fa-upload mr-1"></i> <%= t('confirm_vinyl.source_local') %>
                                </button>
                                <button type="button" onclick="setImgTab('disc', 'url')" id="tab-disc-url" class="flex-1 py-2 text-[10px] font-black uppercase tracking-widest rounded-lg transition-all opacity-50">
                                    <i class="fa-solid fa-link mr-1"></i> <%= t('confirm_vinyl.source_url') %>
                                </button>
                                <button type="button" onclick="setImgTab('disc', 'search')" id="tab-disc-search" class="flex-1 py-2 text-[10px] font-black uppercase tracking-widest rounded-lg transition-all opacity-50">
                                    <i class="fa-solid fa-search mr-1"></i> <%= t('confirm_vinyl.source_search') %>
                                </button>
                            </div>

                            <div id="pane-disc-local" class="img-pane-disc">
                                <label class="flex flex-col items-center justify-center w-full h-32 border-2 border-dashed border-black/10 dark:border-white/10 rounded-2xl cursor-pointer hover:bg-black/5 transition-all">
                                    <i class="fa-solid fa-compact-disc text-2xl opacity-20 mb-2"></i>
                                    <p class="text-xs font-bold opacity-50 italic"><%= t('confirm_vinyl.browse_files') %></p>
                                    <input type="file" id="fileInputDisc" class="hidden" accept="image/*">
                                </label>
                            </div>

                            <div id="pane-disc-url" class="img-pane-disc hidden">
                                <input type="url" id="urlInputDisc" placeholder="https://site.com/mockup.jpg" class="w-full bg-white dark:bg-black/20 border-transparent rounded-lg p-3 text-sm outline-none focus:ring-2 focus:ring-primary-theme">
                            </div>

                            <div id="pane-disc-search" class="img-pane-disc hidden">
                                <div class="flex gap-2 mb-4">
                                    <input type="text" id="queryDisc" value="<%= vinyl.artist %> <%= vinyl.title %> <%= vinyl.variant_color %>" class="flex-grow bg-white dark:bg-black/20 border-transparent rounded-lg p-2 text-sm outline-none focus:ring-2 focus:ring-primary-theme">
                                    <button type="button" onclick="runUniversalSearch('disc')" class="bg-primary-theme text-white px-4 rounded-lg hover:brightness-110"><i class="fa-solid fa-search"></i></button>
                                </div>
                                <div id="resultsDisc" class="grid grid-cols-3 gap-3 max-h-60 overflow-y-auto custom-scrollbar p-1"></div>
                            </div>
                        </div>
                    </div>

                    <div class="mt-6">
                        <label class="block mb-2 text-sm font-bold uppercase tracking-widest opacity-60">
                            <%= t('confirm_vinyl.field_comments') %>
                            <span class="text-xs opacity-50 ml-2 font-normal normal-case"><%= t('confirm_vinyl.comments_hint') %></span>
                        </label>
                        <textarea name="comments" rows="3" class="bg-black/5 dark:bg-white/5 border border-transparent rounded-lg focus:ring-primary-theme focus:border-primary-theme block w-full p-3 placeholder-opacity-50 transition-colors outline-none" placeholder="<%= t('confirm_vinyl.comments_placeholder') %>"></textarea>
                    </div>

                   
                    <input type="hidden" name="discogs_id" value="<%= vinyl.discogs_id %>">
                    <input type="hidden" name="year" value="<%= vinyl.year %>">
                    <input type="hidden" name="label" value="<%= vinyl.label %>">
                    <input type="hidden" name="catalog_number" value="<%= vinyl.catalog_number %>">
                    <input type="hidden" name="tracklist_json" value="<%= JSON.stringify(vinyl.tracklist) %>">
                    <input type="hidden" name="country" value="<%= vinyl.country %>">

                    <div class="mb-6">
                        <label class="block mb-3 text-sm font-bold uppercase tracking-widest opacity-60"><%= t('confirm_vinyl.field_media_type') %></label>
                        <div class="grid grid-cols-3 gap-3">
                            <label class="cursor-pointer">
                                <input type="radio" name="media_type" value="vinyl" class="peer sr-only" <%= (vinyl.media_type === 'vinyl') ? 'checked' : '' %>>
                                <div class="p-3 rounded-xl border border-transparent bg-black/5 dark:bg-white/5 text-center transition-all peer-checked:bg-primary-theme peer-checked:text-white hover:bg-black/10 dark:hover:bg-white/10 opacity-70 peer-checked:opacity-100">
                                    <i class="fa-solid fa-record-vinyl block mb-1"></i>
                                    <span class="text-xs font-bold"><%= t('media.vinyl') %></span>
                                </div>
                            </label>
                            
                            <label class="cursor-pointer">
                                <input type="radio" name="media_type" value="cd" class="peer sr-only" <%= (vinyl.media_type === 'cd') ? 'checked' : '' %>>
                                <div class="p-3 rounded-xl border border-transparent bg-black/5 dark:bg-white/5 text-center transition-all peer-checked:bg-primary-theme peer-checked:text-white hover:bg-black/10 dark:hover:bg-white/10 opacity-70 peer-checked:opacity-100">
                                    <i class="fa-solid fa-compact-disc block mb-1"></i>
                                    <span class="text-xs font-bold"><%= t('media.cd') %></span>
                                </div>
                            </label>

                            <label class="cursor-pointer">
                                <input type="radio" name="media_type" value="cassette" class="peer sr-only" <%= (vinyl.media_type === 'cassette') ? 'checked' : '' %>>
                                <div class="p-3 rounded-xl border border-transparent bg-black/5 dark:bg-white/5 text-center transition-all peer-checked:bg-primary-theme peer-checked:text-white hover:bg-black/10 dark:hover:bg-white/10 opacity-70 peer-checked:opacity-100">
                                    <i class="fa-solid fa-tape block mb-1"></i>
                                    <span class="text-xs font-bold"><%= t('media.cassette') %></span>
                                </div>
                            </label>
                        </div>
                    </div>

                    <div class="mb-6 grid grid-cols-1 md:grid-cols-2 gap-6">
                        <div>
                            <label class="block text-xs font-bold uppercase tracking-wider opacity-60 mb-2">
                                <i class="fa-solid fa-box-archive mr-1"></i> <%= t('common.location') %>
                            </label>
                            <input type="text" name="location" list="locationList" 
                                value="<%= typeof vinyl !== 'undefined' ? (vinyl.location || '') : '' %>"
                                placeholder="<%= t('placeholders.location') %>"
                                class="w-full bg-black/5 dark:bg-white/5 border border-transparent rounded-lg px-4 py-3 text-sm focus:ring-2 focus:ring-primary-theme outline-none transition-all">
                            
                            <datalist id="locationList">
                                <% locations.forEach(loc => { %>
                                    <option value="<%= loc %>">
                                <% }) %>
                            </datalist>
                        </div>
                    </div>

                    <div class="mb-6 grid grid-cols-1 md:grid-cols-2 gap-6">
                        <div>
                            <label class="block text-xs font-bold uppercase tracking-wider opacity-60 mb-2">
                                <i class="fa-solid fa-compact-disc mr-1"></i> <%= t('confirm_vinyl.field_genres') %>
                            </label>
                            <input type="text" name="genres" 
                                value="<%= typeof vinyl !== 'undefined' ? (vinyl.genres ? vinyl.genres.join(', ') : '') : '' %>"
                                placeholder="Rock, Pop..."
                                class="w-full bg-black/5 dark:bg-white/5 border border-transparent rounded-lg px-4 py-3 text-sm focus:ring-2 focus:ring-primary-theme outline-none transition-all">
                        </div>
                        <div>
                            <label class="block text-xs font-bold uppercase tracking-wider opacity-60 mb-2">
                                <i class="fa-solid fa-tags mr-1"></i> <%= t('confirm_vinyl.field_styles') %>
                            </label>
                            <input type="text" name="styles" 
                                value="<%= typeof vinyl !== 'undefined' ? (vinyl.styles ? vinyl.styles.join(', ') : '') : '' %>"
                                placeholder="Prog Rock, Synth-pop..."
                                class="w-full bg-black/5 dark:bg-white/5 border border-transparent rounded-lg px-4 py-3 text-sm focus:ring-2 focus:ring-primary-theme outline-none transition-all">
                        </div>
                    </div>

                    <div class="pt-6 grid grid-cols-1 md:grid-cols-2 gap-4">
                        <button type="submit" name="in_wishlist" value="true" class="bg-black/5 dark:bg-white/5 hover:bg-pink-500 hover:text-white font-bold rounded-lg text-sm px-5 py-4 transition-colors flex items-center justify-center gap-2">
                            <i class="fa-solid fa-gift"></i> <%= t('confirm_vinyl.btn_wishlist') %>
                        </button>
                        <button type="submit" name="in_wishlist" value="false" class="text-white bg-primary-theme hover:brightness-110 font-bold rounded-lg text-lg px-5 py-4 transition-transform hover:scale-[1.01] flex items-center justify-center gap-2 shadow-lg shadow-primary-theme/20">
                            <i class="fa-solid fa-check"></i> <%= t('confirm_vinyl.btn_collection') %>
                        </button>
                    </div>
                </form>
            </div>
        </div>
    </div>
</div>

<script>
    const translations = {
        noResults: "<%= t('confirm_vinyl.no_results') %>",
        networkError: "<%= t('confirm_vinyl.network_error') %>",
        compressAlert: "<%= t('image_source.compress_alert') %>",
        loadingHtml: '<div class="col-span-full py-8 text-center opacity-50"><i class="fa-solid fa-spinner fa-spin text-xl"></i></div>'
    };

    const nodes = {
        checkCover: document.getElementById('checkEditCover'),
        boxCover: document.getElementById('boxEditCover'),
        checkDisc: document.getElementById('checkEditDisc'),
        boxDisc: document.getElementById('boxEditDisc'),
        livePreview: document.getElementById('livePreview')
    };

    function toggleBox(checkbox, box) {
        if (checkbox && box) {
            checkbox.checked ? box.classList.remove('hidden') : box.classList.add('hidden');
        }
    }

    if (nodes.checkCover && nodes.boxCover) {
        toggleBox(nodes.checkCover, nodes.boxCover);
        nodes.checkCover.addEventListener('change', () => toggleBox(nodes.checkCover, nodes.boxCover));
    }
    if (nodes.checkDisc && nodes.boxDisc) {
        toggleBox(nodes.checkDisc, nodes.boxDisc);
        nodes.checkDisc.addEventListener('change', () => toggleBox(nodes.checkDisc, nodes.boxDisc));
    }

    function setImgTab(type, mode) {
        document.querySelectorAll(`.img-pane-${type}`).forEach(p => p.classList.add('hidden'));
        const targetPane = document.getElementById(`pane-${type}-${mode}`);
        if (targetPane) targetPane.classList.remove('hidden');
        
        document.querySelectorAll(`[id^="tab-${type}-"]`).forEach(btn => {
            btn.classList.remove('bg-primary-theme', 'text-white');
            btn.classList.add('opacity-50');
        });
        const activeBtn = document.getElementById(`tab-${type}-${mode}`);
        if (activeBtn) {
            activeBtn.classList.add('bg-primary-theme', 'text-white');
            activeBtn.classList.remove('opacity-50');
        }
    }

    function updateImageValue(type, source, element = null) {
        const inputId = (type === 'cover') ? 'inputCoverImage' : 'inputUserImage';
        const resultsId = (type === 'cover') ? 'resultsCover' : 'resultsDisc';
        
        const hiddenInput = document.getElementById(inputId);
        if (hiddenInput) hiddenInput.value = source;
        
        if (type === 'cover' && nodes.livePreview) {
            nodes.livePreview.src = source;
        }

        if (element) {
            const resultsDiv = document.getElementById(resultsId);
            resultsDiv.querySelectorAll('img').forEach(img => {
                img.classList.remove('ring-4', 'ring-primary-theme', 'border-primary-theme');
                img.classList.add('border-transparent');
            });
            element.classList.add('ring-4', 'ring-primary-theme', 'border-primary-theme');
            element.classList.remove('border-transparent');
        }
    }

    async function runUniversalSearch(type) {
        const queryId = (type === 'cover' ? 'queryCover' : 'queryDisc');
        const resultsId = (type === 'cover' ? 'resultsCover' : 'resultsDisc');
        const q = document.getElementById(queryId).value;
        const resultsDiv = document.getElementById(resultsId);
        
        resultsDiv.innerHTML = translations.loadingHtml;

        try {
            let urls = [];
            const endpoint = (type === 'disc')
                ? `<%= baseUrl %>/admin/api/search-discogs-gallery?q=${encodeURIComponent(q)}`
                : `<%= baseUrl %>/admin/api/search-image-universal?q=${encodeURIComponent(q)}&type=music`;

            const res = await fetch(endpoint);
            urls = await res.json();

            resultsDiv.innerHTML = '';
            if (urls.length === 0) {
                resultsDiv.innerHTML = `<p class="col-span-full text-xs text-center opacity-50 py-8 italic">${translations.noResults}</p>`;
                return;
            }

            urls.forEach(url => {
                const img = document.createElement('img');
                img.src = url;
                img.className = "aspect-square object-contain bg-black/5 dark:bg-white/5 rounded-xl cursor-pointer border-4 border-transparent hover:border-primary-theme/30 transition-all p-1 shadow-sm";
                img.onclick = () => updateImageValue(type, url, img);
                resultsDiv.appendChild(img);
            });
        } catch (e) {
            resultsDiv.innerHTML = `<p class="col-span-full text-xs text-red-500 text-center py-8">${translations.networkError}</p>`;
        }
    }
    
    function compressAndStore(file, type) {
        const reader = new FileReader();
        reader.onload = (ev) => {
            const img = new Image();
            img.onload = () => {
                const canvas = document.createElement('canvas');
                let width = img.width;
                let height = img.height;
                const MAX_SIZE = 800;
                if (width > height) {
                    if (width > MAX_SIZE) { height *= MAX_SIZE / width; width = MAX_SIZE; }
                } else {
                    if (height > MAX_SIZE) { width *= MAX_SIZE / height; height = MAX_SIZE; }
                }
                canvas.width = width; canvas.height = height;
                const ctx = canvas.getContext('2d');
                ctx.drawImage(img, 0, 0, width, height);
                const dataUrl = canvas.toDataURL('image/jpeg', 0.8);
                updateImageValue(type.toLowerCase(), dataUrl);
            };
            img.src = ev.target.result;
        };
        reader.readAsDataURL(file);
    }

    ['Cover', 'Disc'].forEach(type => {
        const urlInput = document.getElementById(`urlInput${type}`);
        const fileInput = document.getElementById(`fileInput${type}`);

        if (urlInput) {
            urlInput.addEventListener('input', (e) => {
                if (e.target.value.startsWith('http')) {
                    updateImageValue(type.toLowerCase(), e.target.value);
                }
            });
        }

        if (fileInput) {
            fileInput.addEventListener('change', function(e) {
                const file = e.target.files[0];
                if (file) {
                    if (file.size > 5 * 1024 * 1024) alert(translations.compressAlert);
                    compressAndStore(file, type);
                }
            });
        }
    });
</script>

<style>
    .custom-scrollbar::-webkit-scrollbar { width: 4px; }
