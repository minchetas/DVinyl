<%- include('partials/header') %>

<div class="max-w-screen-xl mx-auto pb-20 px-4 md:px-0 pt-6">
    
    <nav class="flex mb-6 text-sm opacity-60 transition-colors">
        <a href="<%= baseUrl %>/dvd/<%= dvd._id %>" class="hover:opacity-100 transition-opacity flex items-center py-2">
            <i class="fa-solid fa-arrow-left mr-2"></i> <%= t('common.cancel') %>
        </a>
    </nav>

    <div class="grid grid-cols-1 lg:grid-cols-12 gap-8">
        
        <div class="lg:col-span-4 space-y-6">
            <div class="card-theme rounded-xl p-6 sticky top-24 transition-colors shadow-sm">
                
                <div class="aspect-[2/3] rounded-lg overflow-hidden mb-4 shadow-lg relative group bg-black/5 dark:bg-white/5">
                    <img id="livePreview" src="<%= dvd.cover_image %>" class="w-full h-full object-cover transition-all duration-500">
                    <div class="absolute inset-0 bg-black/40 hidden group-hover:flex items-center justify-center text-white text-xs font-bold backdrop-blur-sm cursor-pointer" onclick="document.getElementById('checkEditCover').click()">
                        <%= t('confirm_vinyl.replace_cover') %>
                    </div>
                    <div class="absolute top-2 right-2 bg-black/70 text-white text-[10px] font-bold px-2 py-1 rounded backdrop-blur-sm uppercase">
                        <%= dvd.media_type === 'tv' ? t('confirm_dvd.tv_show') : t('confirm_dvd.movie') %>
                    </div>
                </div>
                
                <h2 class="text-xl font-bold mb-1 leading-tight"><%= dvd.title %></h2>
                <p class="opacity-60 mb-4"><%= dvd.director %></p>
            </div>
        </div>

        <div class="lg:col-span-8">
            <div class="card-theme rounded-xl p-6 md:p-8 transition-colors shadow-sm">
                <h1 class="text-2xl font-bold mb-6 flex items-center gap-2">
                    <i class="fa-solid fa-pen-to-square text-primary-theme"></i> <%= t('edit_dvd.title') %>
                </h1>

                <form action="<%= baseUrl %>/save-dvd" method="POST" class="space-y-6">
                    <input type="hidden" name="mongo_id" value="<%= dvd._id %>">
                    <input type="hidden" name="tmdb_id" value="<%= dvd.tmdb_id || '' %>">
                    <input type="hidden" name="media_type" value="<%= dvd.media_type || 'movie' %>">
                    <input type="hidden" name="in_wishlist" value="<%= dvd.in_wishlist %>">
                    
                    <div class="grid grid-cols-1 md:grid-cols-2 gap-6">
                        <div>
                            <label class="block mb-2 text-sm font-bold uppercase tracking-widest opacity-60"><%= t('confirm_dvd.field_title') %></label>
                            <input type="text" name="title" value="<%= dvd.title %>" class="bg-black/5 dark:bg-white/5 border border-transparent rounded-lg text-sm focus:ring-primary-theme focus:border-primary-theme block w-full p-3 transition-colors outline-none" required>
                        </div>
                        <div>
                            <label class="block mb-2 text-sm font-bold uppercase tracking-widest opacity-60"><%= t('confirm_dvd.field_director') %></label>
                            <input type="text" name="director" value="<%= dvd.director %>" class="bg-black/5 dark:bg-white/5 border border-transparent rounded-lg text-sm focus:ring-primary-theme focus:border-primary-theme block w-full p-3 transition-colors outline-none" required>
                        </div>
                    </div>

                    <div class="grid grid-cols-1 md:grid-cols-2 gap-6">
                        <div>
                            <label class="block mb-2 text-sm font-bold uppercase tracking-widest opacity-60"><%= t('confirm_dvd.field_studio') %></label>
                            <input type="text" name="studio" value="<%= dvd.studio %>" class="bg-black/5 dark:bg-white/5 border border-transparent rounded-lg text-sm focus:ring-primary-theme block w-full p-3 transition-colors outline-none">
                        </div>
                        <div class="grid grid-cols-2 gap-4">
                            <div>
                                <label class="block mb-2 text-sm font-bold uppercase tracking-widest opacity-60"><%= t('confirm_dvd.field_year') %></label>
                                <input type="text" name="year" value="<%= dvd.year %>" class="bg-black/5 dark:bg-white/5 border border-transparent rounded-lg text-sm focus:ring-primary-theme block w-full p-3 transition-colors outline-none">
                            </div>
                            <div>
                                <label class="block mb-2 text-sm font-bold uppercase tracking-widest opacity-60"><%= t('confirm_dvd.field_duration') %></label>
                                <input type="text" name="duration" value="<%= dvd.duration %>" class="bg-black/5 dark:bg-white/5 border border-transparent rounded-lg text-sm focus:ring-primary-theme block w-full p-3 transition-colors outline-none">
                            </div>
                        </div>
                    </div>

                    <div class="grid grid-cols-1 md:grid-cols-3 gap-6">
                        <div>
                            <label class="block mb-2 text-sm font-bold uppercase tracking-widest text-primary-theme opacity-60">
                                <%= t('confirm_dvd.field_format') %>
                            </label>
                            <select name="format" class="bg-black/5 dark:bg-white/5 border border-transparent text-gray-900 dark:text-white text-sm rounded-lg focus:ring-primary-theme focus:border-primary-theme block w-full p-3 transition-colors outline-none cursor-pointer">
                                <option value="dvd" class="bg-white dark:bg-[#1a1a1a]" <%= dvd.format === 'dvd' ? 'selected' : '' %>>DVD</option>
                                <option value="bluray" class="bg-white dark:bg-[#1a1a1a]" <%= dvd.format === 'bluray' ? 'selected' : '' %>>Blu-ray</option>
                                <option value="4k" class="bg-white dark:bg-[#1a1a1a]" <%= dvd.format === '4k' ? 'selected' : '' %>>4K UHD</option>
                                <option value="vhs" class="bg-white dark:bg-[#1a1a1a]" <%= dvd.format === 'vhs' ? 'selected' : '' %>>VHS</option>
                                <option value="laserdisc" class="bg-white dark:bg-[#1a1a1a]" <%= dvd.format === 'laserdisc' ? 'selected' : '' %>>Laserdisc</option>
                            </select>
                        </div>
                        <div>
                            <label class="block mb-2 text-sm font-bold uppercase tracking-widest opacity-60"><%= t('confirm_dvd.field_barcode') %></label>
                            <input type="text" name="barcode" value="<%= dvd.barcode || '' %>" class="bg-black/5 dark:bg-white/5 border border-transparent rounded-lg text-sm focus:ring-primary-theme block w-full p-3 transition-colors outline-none">
                        </div>
                        <div>
                            <label class="block mb-2 text-sm font-bold uppercase tracking-widest opacity-60"><%= t('confirm_vinyl.field_quantity') %></label>
                            <input type="number" name="quantity" value="<%= dvd.quantity || 1 %>" min="1" class="bg-black/5 dark:bg-white/5 border border-transparent rounded-lg text-sm focus:ring-primary-theme block w-full p-3 transition-colors outline-none">
                        </div>
                    </div>

                    <div class="flex items-center">
                        <input id="is_boxset" type="checkbox" name="is_boxset" value="true" <%= dvd.is_boxset ? 'checked' : '' %> class="w-4 h-4 text-primary-theme bg-black/5 dark:bg-white/10 border-transparent rounded focus:ring-primary-theme focus:ring-2 cursor-pointer transition-colors">
                        <label for="is_boxset" class="ml-2 text-sm font-bold cursor-pointer opacity-80 hover:opacity-100 transition-opacity">
                            <%= t('confirm_dvd.is_boxset') %>
                        </label>
                    </div>

                    <hr class="border-black/10 dark:border-white/10 my-6 transition-colors">

                    <h2 class="text-lg font-bold mb-4 flex items-center gap-2">
                        <i class="fa-solid fa-eye text-primary-theme"></i> <%= t('confirm_dvd.watch_tracking') %>
                    </h2>
                    <div class="grid grid-cols-1 md:grid-cols-2 gap-6 mb-6">
                        <div>
                            <label class="block mb-2 text-sm font-bold uppercase tracking-widest opacity-60"><%= t('confirm_book.field_status') %></label>
                            <select name="watchStatus" class="bg-black/5 dark:bg-white/5 border border-transparent text-gray-900 dark:text-white text-sm rounded-lg focus:ring-primary-theme focus:border-primary-theme block w-full p-3 transition-colors outline-none cursor-pointer">
                                <option class="bg-white dark:bg-[#1a1a1a]" value="to_watch" <%= dvd.watchStatus === 'to_watch' ? 'selected' : '' %>><%= t('confirm_dvd.status_to_watch') %></option>
                                <option class="bg-white dark:bg-[#1a1a1a]" value="watching" <%= dvd.watchStatus === 'watching' ? 'selected' : '' %>><%= t('confirm_dvd.status_watching') %></option>
                                <option class="bg-white dark:bg-[#1a1a1a]" value="watched" <%= dvd.watchStatus === 'watched' ? 'selected' : '' %>><%= t('confirm_dvd.status_watched') %></option>
                            </select>
                        </div>
                        <div>
                            <label class="block mb-2 text-sm font-bold uppercase tracking-widest opacity-60"><%= t('confirm_book.field_rating') %></label>
                            <input type="number" name="user_rating" min="0" max="5" step="0.5" value="<%= dvd.user_rating || 0 %>" class="bg-black/5 dark:bg-white/5 border border-transparent rounded-lg text-sm focus:ring-primary-theme block w-full p-3 transition-colors outline-none">
                        </div>
                    </div>

                    <hr class="border-black/10 dark:border-white/10 my-6 transition-colors">

                    <div class="space-y-4">
                        <div class="flex items-center">
                            <input id="checkEditCover" type="checkbox" class="w-4 h-4 text-primary-theme bg-black/5 dark:bg-white/10 border-transparent rounded focus:ring-primary-theme focus:ring-2 cursor-pointer transition-colors">
                            <label for="checkEditCover" class="ml-2 text-sm font-bold cursor-pointer opacity-80 hover:opacity-100 transition-opacity">
                                <%= t('confirm_vinyl.replace_cover') %>
                            </label>
                        </div>

                        <input type="hidden" name="cover_image" id="inputCoverImage" value="<%= dvd.cover_image %>">

                        <div id="boxEditCover" class="hidden p-4 card-theme rounded-2xl border border-black/10 dark:border-white/10 shadow-inner transition-all">
                            
                            <div class="flex gap-1 mb-6 p-1 bg-black/5 dark:bg-white/5 rounded-xl">
                                <button type="button" onclick="setImgTab('local')" id="tab-local" class="flex-1 py-2 text-[10px] font-black uppercase tracking-widest rounded-lg transition-all bg-primary-theme text-white">
                                    <i class="fa-solid fa-upload mr-1"></i> <%= t('image_source.local') %>
                                </button>
                                <button type="button" onclick="setImgTab('url')" id="tab-url" class="flex-1 py-2 text-[10px] font-black uppercase tracking-widest rounded-lg transition-all opacity-50">
                                    <i class="fa-solid fa-link mr-1"></i> <%= t('image_source.url') %>
                                </button>
                                <button type="button" onclick="setImgTab('search')" id="tab-search" class="flex-1 py-2 text-[10px] font-black uppercase tracking-widest rounded-lg transition-all opacity-50">
                                    <i class="fa-solid fa-search mr-1"></i> <%= t('image_source.search') %>
                                </button>
                            </div>

                            <div id="pane-local" class="img-pane">
                                <label class="flex flex-col items-center justify-center w-full h-32 border-2 border-dashed border-black/10 dark:border-white/10 rounded-2xl cursor-pointer hover:bg-black/5 transition-all">
                                    <div class="flex flex-col items-center justify-center py-4">
                                        <i class="fa-solid fa-cloud-arrow-up text-2xl opacity-20 mb-2"></i>
                                        <p class="text-xs font-bold opacity-50 italic"><%= t('image_source.hint') %></p>
                                    </div>
                                    <input type="file" id="fileInput" class="hidden" accept="image/*">
                                </label>
                            </div>

                            <div id="pane-url" class="img-pane hidden">
                                <label class="block mb-2 text-[10px] font-black uppercase opacity-40"><%= t('image_source.url_label') %></label>
                                <input type="url" id="urlInput" placeholder="https://site.com/affiche.jpg" class="w-full bg-white dark:bg-black/20 border-transparent rounded-lg p-3 text-sm outline-none focus:ring-2 focus:ring-primary-theme">
                            </div>

                            <div id="pane-search" class="img-pane hidden">
                                <div class="flex gap-2 mb-4">
                                    <input type="text" id="queryCover" value="<%= dvd.title %>" class="flex-grow bg-white dark:bg-black/20 border-transparent rounded-lg p-2 text-sm outline-none focus:ring-2 focus:ring-primary-theme">
                                    <button type="button" onclick="runUniversalSearch()" class="bg-primary-theme text-white px-4 rounded-lg">
                                        <i class="fa-solid fa-search"></i>
                                    </button>
                                </div>
                                <div id="resultsCover" class="grid grid-cols-3 gap-2 max-h-48 overflow-y-auto custom-scrollbar"></div>
                            </div>
                        </div>
                    </div>

                    <div>
                        <label class="block mb-2 text-sm font-bold uppercase tracking-widest opacity-60">
                            <%= t('confirm_vinyl.field_comments') %>
                        </label>
                        <textarea name="comments" rows="3" class="bg-black/5 dark:bg-white/5 border border-transparent rounded-lg focus:ring-primary-theme focus:border-primary-theme block w-full p-3 placeholder-opacity-50 transition-colors outline-none"><%= dvd.comments || '' %></textarea>
                    </div>

                    <div class="mb-6 grid grid-cols-1 md:grid-cols-2 gap-6">
                        <div>
                            <label class="block text-xs font-bold uppercase tracking-wider opacity-60 mb-2">
                                <i class="fa-solid fa-box-archive mr-1"></i> <%= t('common.location') %>
                            </label>
                            <input type="text" name="location" list="locationList" value="<%= dvd.location || '' %>"
                                class="w-full bg-black/5 dark:bg-white/5 border border-transparent rounded-lg px-4 py-3 text-sm focus:ring-2 focus:ring-primary-theme outline-none transition-all">
                            
                            <datalist id="locationList">
                                <% locations.forEach(loc => { %>
                                    <option value="<%= loc %>">
                                <% }) %>
                            </datalist>
                        </div>
                        <div>
                            <label class="block text-xs font-bold uppercase tracking-wider opacity-60 mb-2">
                                <i class="fa-solid fa-film mr-1"></i> <%= t('confirm_vinyl.field_genres') %>
                            </label>
                            <input type="text" name="genres" 
                                placeholder="Action, Sci-Fi..."
                                value="<%= dvd.genres ? dvd.genres.join(', ') : '' %>"
                                class="w-full bg-black/5 dark:bg-white/5 border border-transparent rounded-lg px-4 py-3 text-sm focus:ring-2 focus:ring-primary-theme outline-none transition-all">
                        </div>
                        <div>
                            <label class="block text-xs font-bold uppercase tracking-wider opacity-60 mb-2">
                                <i class="fa-solid fa-tags mr-1"></i> <%= t('confirm_vinyl.field_styles') %>
                            </label>
                            <input type="text" name="styles" 
                                placeholder="Cyberpunk, Noir..."
                                value="<%= dvd.styles ? dvd.styles.join(', ') : '' %>"
                                class="w-full bg-black/5 dark:bg-white/5 border border-transparent rounded-lg px-4 py-3 text-sm focus:ring-2 focus:ring-primary-theme outline-none transition-all">
                        </div>
                    </div>

                    <div class="pt-6">
                        <button type="submit" class="w-full text-white bg-primary-theme hover:brightness-110 font-bold rounded-lg text-lg px-5 py-4 transition-transform hover:scale-[1.01] flex items-center justify-center gap-2 shadow-lg shadow-primary-theme/20">
                            <i class="fa-solid fa-save"></i> <%= t('common.save') %>
                        </button>
                    </div>
                </form>
            </div>
        </div>
    </div>
</div>

<script>
    const translations = {
        compressAlert: "<%= t('image_source.compress_alert') %>"
    };

    const checkCover = document.getElementById('checkEditCover');
    const boxCover = document.getElementById('boxEditCover');

    function toggleBox() {
        if (checkCover.checked) {
            boxCover.classList.remove('hidden');
        } else {
            boxCover.classList.add('hidden');
        }
    }

    if (checkCover && boxCover) {
        toggleBox();
        checkCover.addEventListener('change', toggleBox);
    }

    const queryInput = document.getElementById('queryCover');
    const resultsDiv = document.getElementById('resultsCover');
    const hiddenInput = document.getElementById('inputCoverImage');
    const livePreview = document.getElementById('livePreview');

    function setImgTab(mode) {
        document.querySelectorAll('.img-pane').forEach(p => p.classList.add('hidden'));
        document.getElementById(`pane-${mode}`).classList.remove('hidden');
        document.querySelectorAll('[id^="tab-"]').forEach(btn => {
            btn.classList.remove('bg-primary-theme', 'text-white');
            btn.classList.add('opacity-50');
        });
        const active = document.getElementById(`tab-${mode}`);
        active.classList.add('bg-primary-theme', 'text-white');
        active.classList.remove('opacity-50');
    }

    function updatePreview(source) {
        document.getElementById('inputCoverImage').value = source;
        const preview = document.getElementById('livePreview') || document.getElementById('mainImage');
        if (preview) preview.src = source;
    }

    async function runUniversalSearch() {
        const q = document.getElementById('queryCover').value;
        const resultsDiv = document.getElementById('resultsCover');
        resultsDiv.innerHTML = '<div class="col-span-full py-4 text-center opacity-50"><i class="fa-solid fa-spinner fa-spin"></i></div>';
        try {
            const res = await fetch(`<%= baseUrl %>/admin/api/search-image-universal?q=${encodeURIComponent(q)}&type=movie`);
            const urls = await res.json();
            
            resultsDiv.innerHTML = '';
            urls.forEach(url => {
                const img = document.createElement('img');
                img.src = url;
                img.className = "aspect-[2/3] object-cover rounded-lg cursor-pointer border-2 border-transparent hover:border-primary-theme transition-all shadow-sm";
                img.onclick = () => updatePreview(url);
                resultsDiv.appendChild(img);
            });
        } catch (e) {
            resultsDiv.innerHTML = '<p class="col-span-full text-xs text-red-500 text-center">Erreur de recherche.</p>';
        }
    }

    document.getElementById('urlInput').addEventListener('input', (e) => {
        const val = e.target.value.trim();
        if (val.startsWith('http')) updatePreview(val);
    });

    document.getElementById('fileInput').addEventListener('change', function(e) {
        const file = e.target.files[0];
        if (file) {
            if (file.size > 5 * 1024 * 1024) alert(translations.compressAlert);
            const reader = new FileReader();
            reader.onload = (ev) => {
                const img = new Image();
                img.onload = () => {
                    const canvas = document.createElement('canvas');
                    let width = img.width;
                    let height = img.height;
                    const MAX_SIZE = 800;
                    if (width > height) {
                        if (width > MAX_SIZE) { height *= MAX_SIZE / width; width = MAX_SIZE; }
                    } else {
                        if (height > MAX_SIZE) { width *= MAX_SIZE / height; height = MAX_SIZE; }
                    }
                    canvas.width = width; canvas.height = height;
                    const ctx = canvas.getContext('2d');
                    ctx.drawImage(img, 0, 0, width, height);
                    const dataUrl = canvas.toDataURL('image/jpeg', 0.8);
                    updatePreview(dataUrl);
                };
                img.src = ev.target.result;
            };
            reader.readAsDataURL(file);
        }
    });
</script>

<style>
    .custom-scrollbar::-webkit-scrollbar { width: 4px; }
    .custom-scrollbar::-webkit-scrollbar-track { background: transparent; }
    .custom-scrollbar::-webkit-scrollbar-thumb { background: rgba(100,100,100,0.2); border-radius: 2px; }
    .dark .custom-scrollbar::-webkit-scrollbar-thumb { background: rgba(255,255,255,0.1); }
</style>

<%- include('partials/footer') %>
