<%- include('partials/header') %>

<div class="max-w-screen-xl mx-auto pb-20 px-4 md:px-0">
    
    <nav class="flex mb-6 text-sm opacity-60 transition-colors">
        <a href="/album/<%= vinyl._id %>" class="hover:opacity-100 transition-opacity flex items-center py-2">
            <i class="fa-solid fa-arrow-left mr-2"></i> <%= t('common.cancel_back') %>
        </a>
    </nav>

    <div class="grid grid-cols-1 lg:grid-cols-12 gap-8">
        
        <div class="lg:col-span-4 space-y-6">
            <div class="card-theme rounded-xl p-6 sticky top-24 transition-colors shadow-sm">
                <div class="aspect-square rounded-lg overflow-hidden mb-4 shadow-lg relative group bg-black/5 dark:bg-white/5">
                    <img id="livePreview" src="<%= vinyl.cover_image %>" class="w-full h-full object-cover transition-all duration-500">
                </div>
                <h2 class="text-xl font-bold mb-1"><%= vinyl.title %></h2>
                <p class="opacity-60 mb-4"><%= vinyl.artist %></p>
            </div>
        </div>

        <div class="lg:col-span-8">
            <div class="card-theme rounded-xl p-6 md:p-8 transition-colors shadow-sm">
                <h1 class="text-2xl font-bold mb-6 flex items-center gap-2">
                    <i class="fa-solid fa-pen-to-square text-primary-theme"></i> <%= t('edit_vinyl.title') %>
                </h1>

                <form action="/save-vinyl" method="POST" class="space-y-6">
                    
                    <div class="bg-yellow-50 dark:bg-yellow-900/10 border border-yellow-200 dark:border-yellow-700/30 p-4 rounded-lg transition-colors">
                        <label class="block mb-2 text-sm font-bold text-yellow-700 dark:text-yellow-500 transition-colors">
                            <%= t('edit_vinyl.discogs_id_label') %>
                        </label>
                        <div class="text-xs text-yellow-800/80 dark:text-yellow-200/60 mb-2 transition-colors">
                            <%= t('edit_vinyl.discogs_id_hint') %>
                        </div>
                        <input type="number" name="discogs_id" value="<%= vinyl.discogs_id %>" class="bg-white dark:bg-black/20 border border-yellow-300 dark:border-yellow-600/50 text-sm rounded-lg focus:ring-yellow-500 block w-full p-2.5 font-mono transition-colors">
                    </div>

                    <div class="grid grid-cols-1 md:grid-cols-2 gap-6">
                        <div>
                            <label class="block mb-2 text-sm font-bold uppercase tracking-widest opacity-60"><%= t('confirm_vinyl.field_title') %></label>
                            <input type="text" name="title" value="<%= vinyl.title %>" class="bg-black/5 dark:bg-white/5 border border-transparent rounded-lg text-sm focus:ring-primary-theme focus:border-primary-theme block w-full p-2.5 transition-colors outline-none">
                        </div>
                        <div>
                            <label class="block mb-2 text-sm font-bold uppercase tracking-widest opacity-60"><%= t('confirm_vinyl.field_artist') %></label>
                            <input type="text" name="artist" value="<%= vinyl.artist %>" class="bg-black/5 dark:bg-white/5 border border-transparent rounded-lg text-sm focus:ring-primary-theme focus:border-primary-theme block w-full p-2.5 transition-colors outline-none">
                        </div>
                    </div>

                    <div class="grid grid-cols-1 md:grid-cols-2 gap-6">
                        <div>
                            <label class="block mb-2 text-sm font-bold uppercase tracking-widest opacity-60"><%= t('confirm_vinyl.field_format') %></label>
                            <input type="text" name="format_type" value="<%= vinyl.format_type %>" class="bg-black/5 dark:bg-white/5 border border-transparent rounded-lg text-sm focus:ring-primary-theme focus:border-primary-theme block w-full p-2.5 transition-colors outline-none">
                        </div>
                        <div>
                            <label class="block mb-2 text-sm font-bold uppercase tracking-widest text-primary-theme"><%= t('confirm_vinyl.field_edition') %></label>
                            <input type="text" name="variant_color" value="<%= vinyl.variant_color %>" class="bg-black/5 dark:bg-white/5 border border-primary-theme/30 text-sm rounded-lg focus:ring-primary-theme block w-full p-2.5 transition-colors outline-none">
                        </div>
                    </div>
                    <div class="grid grid-cols-1 md:grid-cols-2 gap-6">
                        <div>
                            <label class="block mb-2 text-sm font-bold uppercase tracking-widest opacity-60"><%= t('confirm_vinyl.field_quantity') %></label>
                            <input type="number" name="quantity" value="<%= vinyl.quantity || 1 %>" min="1" class="bg-black/5 dark:bg-white/5 border border-transparent rounded-lg text-sm focus:ring-primary-theme focus:border-primary-theme block w-full p-2.5 transition-colors outline-none">
                        </div>
                    </div>
                    <hr class="border-black/10 dark:border-white/10 my-6 transition-colors">

                    <div>
                        <label class="block mb-2 text-sm font-bold uppercase tracking-widest opacity-60"><%= t('confirm_vinyl.field_comments') %></label>
                        <textarea name="comments" rows="3" class="bg-black/5 dark:bg-white/5 border border-transparent rounded-lg focus:ring-primary-theme focus:border-primary-theme block w-full p-2.5 transition-colors outline-none"><%= vinyl.comments %></textarea>
                    </div>

                    <div class="mb-6">
                        <label class="block text-xs font-bold uppercase tracking-wider opacity-60 mb-2">
                            <i class="fa-solid fa-box-archive mr-1"></i> <%= t('common.location') %>
                        </label>
                        <input type="text" name="location" list="locationList" 
                            value="<%= typeof vinyl !== 'undefined' ? (vinyl.location || '') : '' %>"
                            placeholder="<%= t('placeholders.location') %>"
                            class="w-full bg-black/5 dark:bg-white/5 border border-transparent rounded-lg px-4 py-3 text-sm focus:ring-2 focus:ring-primary-theme outline-none transition-all">
                        
                        <datalist id="locationList">
                            <% locations.forEach(loc => { %>
                                <option value="<%= loc %>">
                            <% }) %>
                        </datalist>
                    </div>

                    <hr class="border-black/10 dark:border-white/10 my-6 transition-colors">

                    <div>
                        <div class="flex items-center mb-4">
                            <input id="checkEditCover" type="checkbox" class="w-4 h-4 text-primary-theme bg-black/5 dark:bg-white/10 border-transparent rounded focus:ring-primary-theme focus:ring-2 cursor-pointer transition-colors">
                            <label for="checkEditCover" class="ml-2 text-sm font-bold cursor-pointer select-none opacity-80 hover:opacity-100 transition-opacity">
                                <%= t('edit_vinyl.change_cover') %>
                            </label>
                        </div>
                        <input type="hidden" name="cover_image" id="inputCoverImage" value="<%= vinyl.cover_image %>">
                        
                        <div id="boxEditCover" class="hidden p-4 bg-black/5 dark:bg-white/5 rounded-lg border border-black/10 dark:border-white/10 mb-6 transition-colors">
                            <div class="flex gap-2 mb-4">
                                <input type="text" id="queryCover" value="<%= vinyl.artist %> <%= vinyl.title %> cover" class="flex-grow bg-white dark:bg-black/20 border border-transparent text-sm rounded-lg p-2.5 transition-colors outline-none focus:ring-1 focus:ring-primary-theme">
                                <button type="button" onclick="searchGoogle('cover')" class="bg-primary-theme hover:brightness-110 text-white px-4 py-2 rounded-lg transition-colors shadow-md"><i class="fa-solid fa-search"></i></button>
                            </div>
                            <div id="resultsCover" class="grid grid-cols-3 gap-3 max-h-40 overflow-y-auto custom-scrollbar">
                                <p class="col-span-full text-center text-xs opacity-50 py-2"><%= t('confirm_vinyl.search_hint') %></p>
                            </div>
                        </div>
                    </div>

                    <div>
                        <div class="flex items-center mb-4">
                            <input id="checkEditDisc" type="checkbox" <%= vinyl.user_image ? 'checked' : '' %> class="w-4 h-4 text-primary-theme bg-black/5 dark:bg-white/10 border-transparent rounded focus:ring-primary-theme focus:ring-2 cursor-pointer transition-colors">
                            <label for="checkEditDisc" class="ml-2 text-sm font-bold cursor-pointer select-none opacity-80 hover:opacity-100 transition-opacity">
                                <%= t('edit_vinyl.edit_secondary_visual') %>
                            </label>
                        </div>
                        <input type="hidden" name="user_image" id="inputUserImage" value="<%= vinyl.user_image %>">
                        
                        <div id="boxEditDisc" class="hidden p-4 bg-black/5 dark:bg-white/5 rounded-lg border border-primary-theme/30 transition-colors">
                            <div class="flex gap-2 mb-4">
                                <input type="text" id="queryDisc" value="<%= vinyl.artist %> <%= vinyl.title %> vinyl <%= vinyl.variant_color %>" class="flex-grow bg-white dark:bg-black/20 border border-transparent text-sm rounded-lg p-2.5 transition-colors outline-none focus:ring-1 focus:ring-primary-theme">
                                <button type="button" onclick="searchGoogle('disc')" class="bg-primary-theme hover:brightness-110 text-white px-4 py-2 rounded-lg transition-colors shadow-md"><i class="fa-solid fa-search"></i></button>
                            </div>
                            <div id="resultsDisc" class="grid grid-cols-3 gap-3 max-h-40 overflow-y-auto custom-scrollbar">
                                <p class="col-span-full text-center text-xs opacity-50 py-2"><%= t('confirm_vinyl.search_hint') %></p>
                            </div>
                        </div>
                    </div>

                    <input type="hidden" name="year" value="<%= vinyl.year %>">
                    <input type="hidden" name="label" value="<%= vinyl.label %>">
                    <input type="hidden" name="catalog_number" value="<%= vinyl.catalog_number %>">
                    <input type="hidden" name="tracklist_json" value="<%= JSON.stringify(vinyl.tracklist) %>">
                    <input type="hidden" name="media_type" value="<%= vinyl.media_type %>">
                    <input type="hidden" name="in_wishlist" value="<%= vinyl.in_wishlist %>">
                    <input type="hidden" name="mongo_id" value="<%= vinyl._id %>">
                    
                    <button type="submit" class="w-full text-white bg-primary-theme hover:brightness-110 font-bold rounded-xl text-lg px-5 py-4 transition-transform hover:scale-[1.01] flex items-center justify-center gap-2 shadow-lg shadow-primary-theme/20">
                        <i class="fa-solid fa-save"></i> <%= t('common.save_changes') %>
                    </button>

                </form>
            </div>
        </div>
    </div>
</div>

<script>
    const translations = {
        searching: "<%= t('common.searching') %>",
        no_results: "<%= t('common.no_results') %>",
        api_error: "<%= t('confirm_vinyl.api_error') %>"
    };

    const toggleBox = (chk, box) => box.classList.toggle('hidden', !chk.checked);
    
    document.getElementById('checkEditCover').addEventListener('change', (e) => toggleBox(e.target, document.getElementById('boxEditCover')));
    document.getElementById('checkEditDisc').addEventListener('change', (e) => toggleBox(e.target, document.getElementById('boxEditDisc')));
    
    toggleBox(document.getElementById('checkEditCover'), document.getElementById('boxEditCover'));
    toggleBox(document.getElementById('checkEditDisc'), document.getElementById('boxEditDisc'));

    async function searchGoogle(type) {
        const query = document.getElementById(type === 'cover' ? 'queryCover' : 'queryDisc').value;
        const resultsDiv = document.getElementById(type === 'cover' ? 'resultsCover' : 'resultsDisc');
        const hiddenInput = document.getElementById(type === 'cover' ? 'inputCoverImage' : 'inputUserImage');
        const livePreview = document.getElementById('livePreview');

        resultsDiv.innerHTML = `<div class="col-span-full text-center py-2"><i class="fa-solid fa-circle-notch fa-spin text-primary-theme text-xl"></i> ${translations.searching}</div>`;
        
        try {
            const res = await fetch(`/api/google-images?q=${encodeURIComponent(query)}`);
            const images = await res.json();
            resultsDiv.innerHTML = '';
            
            if(images.length === 0) {
                 resultsDiv.innerHTML = `<div class="col-span-full text-center text-xs opacity-50">${translations.no_results}</div>`;
                 return;
            }

            images.forEach(url => {
                const img = document.createElement('img');
                img.src = url;
                img.className = 'w-full h-24 object-cover rounded cursor-pointer border-2 border-transparent hover:border-primary-theme transition-all bg-black/5 dark:bg-white/5';
                img.onclick = () => {
                    hiddenInput.value = url;
                    if(type === 'cover') livePreview.src = url;
                    Array.from(resultsDiv.children).forEach(c => c.classList.remove('border-primary-theme'));
                    img.classList.add('border-primary-theme');
                };
                resultsDiv.appendChild(img);
            });
        } catch(e) { 
            resultsDiv.innerHTML = `<div class="col-span-full text-center text-xs text-red-500">${translations.api_error}</div>`; 
        }
    }
</script>

<style>
    .custom-scrollbar::-webkit-scrollbar { width: 4px; }
    .custom-scrollbar::-webkit-scrollbar-track { background: transparent; }
    .custom-scrollbar::-webkit-scrollbar-thumb { background: rgba(100,100,100,0.2); border-radius: 2px; }
    .dark .custom-scrollbar::-webkit-scrollbar-thumb { background: rgba(255,255,255,0.1); }
</style>

<%- include('partials/footer') %>