<%- include('partials/header') %>

<div class="max-w-screen-xl mx-auto space-y-8 md:space-y-12 pb-12 md:px-0">
    
    <section class="relative card-theme rounded-3xl p-6 md:p-12 shadow-2xl overflow-hidden">
            
        <div class="absolute top-0 right-0 -mt-10 -mr-10 w-64 h-64 bg-primary-theme/10 rounded-full blur-3xl"></div>
        <div class="absolute bottom-0 left-0 -mb-10 -ml-10 w-64 h-64 bg-purple-500/10 rounded-full blur-3xl"></div>

        <div class="relative z-10 text-center space-y-4 md:space-y-6">
            <h1 class="text-3xl md:text-6xl font-black tracking-tight">
                <%= t('index.welcome') %> <span class="text-primary-theme"><%= user.username %></span> !
            </h1>
            <p class="opacity-70 text-base md:text-xl max-w-2xl mx-auto">
                <%= t('index.hero_subtitle') %>
            </p>

            <form action="/collection" method="GET" class="w-full max-w-xl mx-auto mt-8">
                <div class="relative group">
                    <div class="absolute inset-y-0 left-0 flex items-center pl-4 pointer-events-none z-10">
                        <i class="fa-solid fa-search opacity-50 group-focus-within:text-primary-theme transition-colors"></i>
                    </div>
                    <input type="text" name="search" class="block w-full p-4 pl-12 text-base bg-black/5 dark:bg-black/20 border border-transparent focus:border-primary-theme rounded-full focus:ring-2 focus:ring-primary-theme/50 placeholder-opacity-50 transition-all shadow-inner" placeholder="<%= t('index.search_placeholder') %>">
                    <button type="submit" class="absolute right-2 top-2 bottom-2 bg-gray-200 dark:bg-white/10 hover:bg-primary-theme hover:text-white font-medium rounded-full text-sm px-4 transition-colors z-10"><%= t('common.go') %></button>
                </div>
            </form>

            <div class="flex flex-wrap justify-center gap-4 pt-4 text-sm opacity-80">
                <% if (user.isAdmin) { %>
                    <a href="/add-vinyl" class="inline-flex items-center gap-2 hover:text-primary-theme transition-colors">
                        <i class="fa-solid fa-plus-circle"></i> 
                        <span class="hidden sm:inline"><%= t('index.nav_add_full') %></span>
                    </a>
                    <span class="opacity-30">|</span>
                <% } %>
                <a href="/collection" class="inline-flex items-center gap-2 hover:text-primary-theme transition-colors">
                    <i class="fa-solid fa-list"></i> <%= t('index.nav_view_all') %>
                </a>
            </div>
        </div>
    </section>

    <section>
        <div class="flex items-center justify-between mb-4 md:mb-6 px-2">
            <div class="flex items-center gap-2">
                <span class="w-2 h-6 md:h-8 bg-primary-theme rounded-full inline-block"></span>
                <h2 class="text-xl md:text-2xl font-bold"><%= t('index.section_latest') %></h2>
            </div>
            <a href="/collection" class="text-sm font-bold text-primary-theme opacity-90 hover:opacity-100 transition-colors flex items-center gap-1 group whitespace-nowrap">
                <%= t('index.view_everything') %> <i class="fa-solid fa-arrow-right group-hover:translate-x-1 transition-transform"></i>
            </a>
        </div>
        <% if (latestCollection.length > 0) { %>
            <div class="grid grid-cols-2 md:grid-cols-4 gap-4 md:gap-6">
                <% latestCollection.forEach(album => { %>
                    <a href="/album/<%= album._id %>" class="group relative card-theme rounded-xl overflow-hidden hover:border-primary-theme transition-all hover:shadow-lg hover:-translate-y-1">
                        <div class="aspect-square relative overflow-hidden">
                            <img src="<%= album.cover_image %>" class="w-full h-full object-cover transition-transform duration-700 group-hover:scale-110">
                            <% 
                                let badgeColor = 'bg-green-600/90 text-white';
                                let badgeLabel = t('media.vinyl');
                                if (album.media_type === 'cd') { badgeColor = 'bg-blue-600/90 text-white'; badgeLabel = t('media.cd'); }
                                else if (album.media_type === 'cassette') { badgeColor = 'bg-orange-600/90 text-white'; badgeLabel = t('media.cassette'); }
                            %>
                            <span class="absolute top-2 right-2 text-[10px] font-bold px-2 py-1 rounded backdrop-blur-md border border-white/10 shadow-sm <%= badgeColor %>">
                                <%= badgeLabel %>
                            </span>                         
                        </div>
                        <div class="p-3 md:p-4">
                            <h3 class="font-bold truncate text-sm md:text-base"><%= album.title %></h3>
                            <p class="text-xs opacity-60 truncate"><%= album.artist %></p>
                        </div>
                    </a>
                <% }) %>
            </div>
        <% } else { %>
            <div class="text-center py-10 border border-dashed border-gray-300 dark:border-gray-700 rounded-xl opacity-60"><%= t('index.empty_collection') %></div>
        <% } %>
    </section>

    <section>
        <div class="flex items-center justify-between mb-4 md:mb-6 px-2">
            <div class="flex items-center gap-2">
                <span class="w-2 h-6 md:h-8 bg-pink-500 rounded-full inline-block"></span>
                <h2 class="text-xl md:text-2xl font-bold"><%= t('index.section_wishlist') %></h2>
            </div>
            <a href="/wishlist" class="text-sm font-bold text-pink-500 hover:text-pink-400 transition-colors flex items-center gap-1 group whitespace-nowrap">
                <%= t('index.view_everything') %> <i class="fa-solid fa-arrow-right group-hover:translate-x-1 transition-transform"></i>
            </a>
        </div>
        <% if (latestWishlist.length > 0) { %>
            <div class="grid grid-cols-2 md:grid-cols-4 gap-4 md:gap-6">
                <% latestWishlist.forEach(album => { %>
                    <a href="/album/<%= album._id %>" class="group relative card-theme rounded-xl overflow-hidden hover:border-pink-500 transition-all hover:shadow-lg hover:-translate-y-1">
                        <div class="aspect-square relative overflow-hidden">
                            <img src="<%= album.cover_image %>" class="w-full h-full object-cover transition-transform duration-700 group-hover:scale-110">
                        </div>
                        <div class="p-3 md:p-4">
                            <h3 class="font-bold truncate text-sm md:text-base"><%= album.title %></h3>
                            <p class="text-xs opacity-60 truncate"><%= album.artist %></p>
                            <% if(album.variant_color) { %>
                                <div class="flex items-center gap-1 mt-1">
                                    <span class="w-2 h-2 rounded-full bg-pink-500 inline-block flex-shrink-0"></span>
                                    <span class="text-[10px] opacity-60 truncate"><%= album.variant_color %></span>
                                </div>
                            <% } %>
                        </div>
                    </a>
                <% }) %>
            </div>
        <% } else { %>
            <div class="text-center py-10 border border-dashed border-gray-300 dark:border-gray-700 rounded-xl opacity-60"><%= t('index.empty_wishlist') %></div>
        <% } %>
    </section>

    <section>
        <h2 class="text-xl md:text-2xl font-bold mb-6 px-2"><%= t('index.section_stats') %></h2>
        
        <div class="grid grid-cols-1 sm:grid-cols-2 md:grid-cols-4 gap-4 md:gap-6">
            <% 
            const widgetConfig = {
                'total': { label: t('stats.total_label'), val: stats.total, unit: t('stats.albums_unit'), icon: 'fa-database', color: 'bg-primary-theme/20', wide: true },
                
                'vinyl': { label: t('media.vinyls'), val: stats.vinyl, icon: 'fa-record-vinyl', color: 'bg-green-100 dark:bg-green-900/30', text: 'text-green-600' },
                'cd': { label: t('media.cds'), val: stats.cd, icon: 'fa-compact-disc', color: 'bg-blue-100 dark:bg-blue-900/30', text: 'text-blue-600' },
                'cassette': { label: t('media.cassettes'), val: stats.cassette, icon: 'fa-tape', color: 'bg-orange-100 dark:bg-orange-900/30', text: 'text-orange-600' },
                
                'book_total': { label: t('stats.books_total_label'), val: stats.book_total, icon: 'fa-book', color: 'bg-purple-100 dark:bg-purple-900/30', text: 'text-purple-600' },
                'book_manga': { label: t('media.mangas'), val: stats.book_manga, icon: 'fa-book-open', color: 'bg-pink-100 dark:bg-pink-900/30', text: 'text-pink-600' },
                'book_comic': { label: t('media.comics'), val: stats.book_comic, icon: 'fa-mask', color: 'bg-indigo-100 dark:bg-indigo-900/30', text: 'text-indigo-600' },
                'book_hardcover': { label: t('media.hardcover_pl'), val: stats.book_hardcover, icon: 'fa-book-atlas', color: 'bg-violet-100 dark:bg-violet-900/30', text: 'text-violet-600' },
                'book_paperback': { label: t('media.paperback_pl'), val: stats.book_paperback, icon: 'fa-book-journal-whills', color: 'bg-fuchsia-100 dark:bg-fuchsia-900/30', text: 'text-fuchsia-600' },
                
                'dvd_total': { label: t('stats.dvd_total_label'), val: stats.dvd_total, icon: 'fa-film', color: 'bg-blue-100 dark:bg-blue-900/30', text: 'text-blue-600' },
                'dvd_dvd': { label: t('media.dvds'), val: stats.dvd_dvd, icon: 'fa-compact-disc', color: 'bg-sky-100 dark:bg-sky-900/30', text: 'text-sky-600' },
                'dvd_bluray': { label: t('media.blurays'), val: stats.dvd_bluray, icon: 'fa-circle-dot', color: 'bg-indigo-100 dark:bg-indigo-900/30', text: 'text-indigo-600' },
                'dvd_4k': { label: t('media.4k_pl'), val: stats.dvd_4k, icon: 'fa-wand-magic-sparkles', color: 'bg-red-100 dark:bg-red-900/30', text: 'text-red-600' },
                'dvd_vhs': { label: t('media.vhss'), val: stats.dvd_vhs, icon: 'fa-tape', color: 'bg-stone-100 dark:bg-stone-900/30', text: 'text-stone-600' },
                'dvd_laserdisc': { label: t('media.laserdiscs'), val: stats.dvd_laserdisc, icon: 'fa-compact-disc', color: 'bg-teal-100 dark:bg-teal-900/30', text: 'text-teal-600' }
            };

            const topConfigs = {
                'artist': { label: t('stats.top_artist_label'), data: stats.artist, icon: 'fa-crown', color: 'bg-purple-100 dark:bg-purple-500/20' },
                'author': { label: t('stats.top_author_label'), data: stats.author, icon: 'fa-pen-nib', color: 'bg-amber-100 dark:bg-amber-500/20' },
                'director': { label: t('stats.top_director_label'), data: stats.director, icon: 'fa-clapperboard', color: 'bg-red-100 dark:bg-red-500/20' }
            };
            
            const activeWidgets = (settings && settings.statsWidgets) ? settings.statsWidgets : ['total', 'vinyl', 'cd', 'cassette', 'artist'];

            activeWidgets.forEach(id => { 
                const w = widgetConfig[id];
                const tW = topConfigs[id];

                if (w) { %>
                    <div class="card-theme p-6 rounded-2xl flex items-center justify-between transition-all hover:scale-[1.02] <%= w.wide ? 'md:col-span-2' : '' %>">
                        <div>
                            <p class="opacity-60 font-medium text-xs uppercase tracking-wider mb-1"><%= w.label %></p>
                            <h3 class="<%= w.wide ? 'text-4xl md:text-5xl font-black' : 'text-3xl font-bold' %>">
                                <%= w.val %> <% if(w.unit){ %><span class="text-base font-normal opacity-50"><%= w.unit %></span><% } %>
                            </h3>
                        </div>
                        <div class="w-10 h-10 rounded-full <%= w.color %> <%= w.text %> flex items-center justify-center text-lg">
                            <i class="fa-solid <%= w.icon %>"></i>
                        </div>
                    </div>
                <% } else if (tW) { %>
                    <div class="card-theme p-6 rounded-2xl md:col-span-4 flex items-center gap-6 transition-all hover:scale-[1.01]">
                        <div class="w-16 h-16 rounded-full <%= tW.color %> flex items-center justify-center text-3xl flex-shrink-0">
                            <i class="fa-solid <%= tW.icon %>"></i>
                        </div>
                        <div>
                            <p class="opacity-60 font-medium text-sm uppercase tracking-wider"><%= tW.label %></p>
                            <h3 class="text-2xl font-bold"><%= tW.data.name %></h3>
                            <p class="text-sm opacity-60"><%= t('stats.owned_times', { count: tW.data.count }) %></p>
                        </div>
                    </div>
                <% }
            }); %>
        </div>
    </section>

    <div class="md:col-span-4 mt-2">
        <button onclick="openEstimateModal()" class="w-full card-theme hover:brightness-110 border border-transparent hover:border-primary-theme font-bold py-4 px-6 rounded-2xl transition-all flex items-center justify-center gap-3 group hover:shadow-lg">
            <i class="fa-solid fa-calculator text-primary-theme group-hover:scale-110 transition-transform"></i>
            <span><%= t('index.btn_estimate') %></span>
        </button>
    </div>


</div>

<div id="estimateModal" class="fixed inset-0 z-50 hidden bg-black/80 backdrop-blur-sm flex items-center justify-center p-4">
    <div class="card-theme rounded-2xl w-full max-w-lg p-6 md:p-8 shadow-2xl relative">

        <button onclick="closeEstimateModal()" class="absolute top-4 right-4 opacity-50 hover:opacity-100">
            <i class="fa-solid fa-xmark text-xl"></i>
        </button>

        <h3 class="text-2xl font-bold mb-2"><%= t('modal.estimate_title') %></h3>
        <p class="opacity-60 text-sm mb-6"><%= t('modal.estimate_desc') %></p>

        <div id="progressContainer" class="mb-6">
            <div class="w-full bg-gray-200 dark:bg-black/30 rounded-full h-4 mb-2 overflow-hidden">
                <div id="estimateProgress" class="bg-primary-theme h-4 rounded-full transition-all duration-300" style="width: 0%"></div>
            </div>
            <div class="flex justify-between text-xs opacity-60 font-mono">
                <span id="estimateCount">0 / <%= stats.total %></span>
                <span id="estimatePercent">0%</span>
            </div>
        </div>

        <div id="estimateResult" class="hidden text-center space-y-4">
            <div class="p-6 bg-primary-theme/10 border border-primary-theme/30 rounded-xl">
                <p class="text-primary-theme text-sm font-bold uppercase tracking-wider mb-1"><%= t('modal.avg_label') %></p>
                <h4 id="finalPrice" class="text-4xl md:text-5xl font-black">--</h4>
                <p class="text-xs opacity-60 mt-2"><%= t('modal.condition_hint') %></p>
            </div>
            
            <div class="grid grid-cols-2 gap-4 text-xs">
                <div class="bg-gray-100 dark:bg-black/20 p-3 rounded-lg">
                    <span class="opacity-60 block"><%= t('modal.min_label') %></span>
                    <span id="minPrice" class="font-bold text-lg">--</span>
                </div>
                <div class="bg-gray-100 dark:bg-black/20 p-3 rounded-lg">
                    <span class="opacity-60 block"><%= t('modal.max_label') %></span>
                    <span id="maxPrice" class="font-bold text-lg">--</span>
                </div>
            </div>
        </div>

        <div id="startEstimateBtn" class="mt-6 text-center">
            <button onclick="startEstimation()" class="bg-primary-theme hover:brightness-110 text-white font-bold py-3 px-8 rounded-xl transition-colors">
                <%= t('modal.start_btn') %>
            </button>
        </div>
    </div>
</div>

<script>
    // Le script reste le même
    const modal = document.getElementById('estimateModal');
    const startBtn = document.getElementById('startEstimateBtn');
    const resultDiv = document.getElementById('estimateResult');
    const progressBar = document.getElementById('estimateProgress');
    const countSpan = document.getElementById('estimateCount');
    const percentSpan = document.getElementById('estimatePercent');
    
    const estimateErrorMsg = "<%= t('messages.estimate_error') %>";
    const currentLocale = '<%= currentLng === "fr" ? "fr-FR" : "en-US" %>';
    const currentCurrency = '<%= currentLng === "fr" ? "EUR" : "USD" %>';

    let totalAlbums = 0;
    let currentProcessed = 0;
    let totalPriceVG = 0;
    let totalPriceMin = 0;
    let totalPriceMax = 0;

    function openEstimateModal() {
        modal.classList.remove('hidden');
    }

    function closeEstimateModal() {
        modal.classList.add('hidden');
    }

    async function startEstimation() {
        startBtn.classList.add('hidden');
        try {
            const res = await fetch('/api/collection/ids');
            const data = await res.json();
            
            if(!data.success) throw new Error("Server Error");
            
            const albums = data.albums;
            totalAlbums = albums.length;
            currentProcessed = 0;
            totalPriceVG = 0;
            totalPriceMin = 0;
            totalPriceMax = 0;

            for (const album of albums) {
                await estimateOneAlbum(album.discogs_id);
                currentProcessed++;                

                const percent = Math.round((currentProcessed / totalAlbums) * 100);
                if (progressBar) progressBar.style.width = percent + '%';
                if (percentSpan) percentSpan.innerText = percent + '%';
                if (countSpan) countSpan.innerText = `${currentProcessed} / ${totalAlbums}`;

                await new Promise(r => setTimeout(r, 500));
            }

            showResults();
        } catch (err) {
            alert(`${estimateErrorMsg} : ${err.message}`);
            startBtn.classList.remove('hidden');
        }
    }

    async function estimateOneAlbum(id) {
        try {
            const res = await fetch(`/api/estimate/${id}`);
            const data = await res.json();
            if (data.success && data.price) {
                const val = data.price.value;
                totalPriceVG += val;
                totalPriceMin += val; 
                totalPriceMax += (val * 1.3);
            }
        } catch (e) {}
    }

    function showResults() {
        const fmt = (val) => new Intl.NumberFormat(currentLocale, { 
            style: 'currency', 
            currency: currentCurrency 
        }).format(val);

        document.getElementById('finalPrice').innerText = fmt(totalPriceVG);
        document.getElementById('minPrice').innerText = fmt(totalPriceMin);
        document.getElementById('maxPrice').innerText = fmt(totalPriceMax);

        document.getElementById('progressContainer').classList.add('hidden');
        resultDiv.classList.remove('hidden');
    }
</script>

<%- include('partials/footer') %>