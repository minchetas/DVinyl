<%- include('partials/header') %>

    <div class="max-w-screen-xl mx-auto px-1 md:px-0 pb-12">

        <div class="flex items-center justify-between mb-6 md:mb-8 pt-6">

            <h1 class="text-3xl font-bold flex flex-col md:flex-row md:items-center gap-2 md:gap-3 transition-colors truncate mr-4">
                <span class="flex items-center gap-2 md:gap-3 text-primary-theme">
                    <i class="fa-solid fa-gift flex-shrink-0"></i>
                    <span class="truncate">
                        <%= t('wishlist.title') %>
                    </span>
                </span>
                <span
                    class="px-3 md:mt-1.5 py-1 bg-black/5 dark:bg-white/10 rounded-full text-sm font-medium opacity-70 w-fit">
                    <%= albums.length %>
                        <%= t('common.items') %>
                </span>
            </h1>

            <% if (user.isAdmin && user.discogsUsername) { %>
                <button onclick="refreshCollection()" id="refreshBtn"
                    class="flex-shrink-0 w-10 h-10 md:w-auto md:h-auto md:p-2.5 card-theme hover:text-primary-theme hover:border-primary-theme rounded-lg transition-all shadow-sm flex items-center justify-center active:scale-95 group"
                    title="refresh discogs">
                    <i class="fa-solid fa-sync group-hover:rotate-180 transition-transform duration-500"></i>
                </button>
                <% } %>

        </div>

        <% if (albums.length===0) { %>
            <div
                class="text-center py-16 md:py-20 card-theme rounded-xl border-dashed opacity-80 transition-colors shadow-sm">
                <i class="fa-regular fa-heart text-5xl md:text-6xl opacity-20 mb-4 transition-colors"></i>
                <p class="opacity-60 px-4">
                    <%= t('wishlist.empty_msg') %>
                </p>
                <a href="<%= baseUrl %>/add-vinyl"
                    class="text-primary-theme hover:underline mt-2 inline-block font-medium transition-colors">
                    <%= t('wishlist.search_link') %>
                </a>
            </div>
            <% } else { %>
                <div class="grid grid-cols-2 sm:grid-cols-3 md:grid-cols-4 lg:grid-cols-5 gap-4 md:gap-6">
                    <% albums.forEach(album=> { %>
                        <% const isBook=album.kind==='Book' ; const isDvd=album.kind==='Dvd' || (album.tmdb_id
                            !==undefined && album.tmdb_id !==null); const rawFormat=isDvd ? album.format :
                            (album.media_type || album.format); const formatKey=rawFormat ? rawFormat.toLowerCase() :
                            (isBook ? 'book' : 'vinyl' ); let detailUrl=`/album/${album._id}`; if (isBook)
                            detailUrl=`/book/${album._id}`; if (isDvd) detailUrl=`/dvd/${album._id}`; const
                            badgeMap={ 'vinyl' : 'bg-green-600/90' , 'cd' : 'bg-blue-600/90' , 'cassette'
                            : 'bg-orange-600/90' , 'manga' : 'bg-pink-600/90' , 'comic' : 'bg-indigo-600/90'
                            , 'hardcover' : 'bg-purple-600/90' , 'paperback' : 'bg-amber-600/90' , 'book'
                            : 'bg-amber-700/90' , 'dvd' : 'bg-sky-600/90' , 'bluray' : 'bg-indigo-700/90' , '4k'
                            : 'bg-red-600/90' , 'vhs' : 'bg-amber-600/90' , 'laserdisc' : 'bg-purple-600/90' }; let
                            badgeClass=(badgeMap[formatKey] || 'bg-gray-600/90' ) + ' text-white' ; %>

                            <div
                                class="group relative card-theme rounded-xl hover:border-primary-theme transition-all duration-300 hover:shadow-lg hover:-translate-y-1 flex flex-col justify-between overflow-hidden">
                                <a href="<%= baseUrl + detailUrl %>" class="block flex-grow">
                                    <div
                                        class="aspect-square w-full relative overflow-hidden bg-black/5 dark:bg-white/5 flex items-center justify-center">

                                        <% if (isBook || isDvd) { %>
                                            <img src="<%= album.cover_image %>"
                                                class="absolute inset-0 w-full h-full object-cover blur-xl opacity-30 scale-110 pointer-events-none">
                                            <% } %>

                                                <img src="<%= album.cover_image %>"
                                                    class="relative z-10 w-full h-full <%= (isBook || isDvd) ? 'object-contain p-2 md:p-3' : 'object-cover' %> transition-transform duration-500 group-hover:scale-105"
                                                    loading="lazy">

                                                <span
                                                    class="absolute top-1.5 right-1.5 md:top-2 md:right-2 z-20 text-[10px] font-bold px-1.5 py-0.5 md:px-2 md:py-1 rounded backdrop-blur-md border border-white/10 shadow-sm <%= badgeClass %>">
                                                    <%= t('media.' + formatKey) %>
                                                </span>
                                    </div>

                                    <div class="p-3">
                                        <h3 class="font-bold text-xs md:text-sm truncate leading-tight mb-0.5"
                                            title="<%= album.title %>">
                                            <%= album.title %>
                                        </h3>
                                        <p class="text-[10px] md:text-xs opacity-60 truncate mb-2">
                                            <%= album.author || album.artist || album.director || album.artists_sort
                                                || 'Unknow' %>
                                        </p>

                                        <% if(album.variant_color) { %>
                                            <div class="flex items-center gap-1 mb-1">
                                                <span
                                                    class="w-2 h-2 rounded-full bg-primary-theme inline-block flex-shrink-0"></span>
                                                <span class="text-[9px] md:text-[10px] opacity-60 truncate max-w-full">
                                                    <%= album.variant_color %>
                                                </span>
                                            </div>
                                            <% } %>
                                    </div>
                                </a>

                                <% if (user.isAdmin) { %>
                                    <button onclick="moveToCollection('<%= album._id %>')"
                                        class="w-full py-2.5 md:py-2 bg-black/5 dark:bg-white/5 hover:bg-primary-theme hover:text-white text-primary-theme text-[10px] md:text-xs font-bold uppercase transition-colors flex items-center justify-center gap-1.5 border-t border-black/10 dark:border-white/10 active:brightness-90">
                                        <i class="fa-solid fa-check"></i>
                                        <span>
                                            <%= t('wishlist.btn_received') %>
                                        </span>
                                    </button>
                                    <% } %>
                            </div>
                            <% }) %>
                </div>
                <% } %>
    </div>

    <script src="<%= baseUrl %>/socket.io/socket.io.js"></script>
    <script>
        const wishlistTranslations = {
            confirmMove: "<%= t('wishlist.confirm_move') %>",
            serverError: "<%= t('messages.generic_error') %>"
        };

        async function moveToCollection(id) {
            if (confirm(wishlistTranslations.confirmMove)) {
                try {
                    const res = await fetch(`<%= baseUrl %>/api/album/${id}/move-to-collection`, { method: 'POST' });
                    const data = await res.json();
                    if (data.success) {
                        window.location.reload();
                    }
                } catch (e) {
                    alert(wishlistTranslations.serverError);
                }
            }
        }

    <% if (user.isAdmin) { %>
        const socket = io({
            path: '<%= baseUrl %>/socket.io',
        });

        async function refreshCollection() {
            const btn = document.getElementById('refreshBtn');
            const icon = btn.querySelector('i');

            icon.classList.add('fa-spin');
            btn.disabled = true;

            socket.once('import_finished', (data) => {
                window.location.reload();
            });

            socket.once('import_error', (data) => {
                alert("import error: " + data.message);
                icon.classList.remove('fa-spin');
                btn.disabled = false;
            });
            try {
                const pseudo = "<%= user.discogsUsername %>";
                let fakeUrl = `https://www.discogs.com/user/${pseudo}`;

                const isWishlistPage = window.location.pathname.includes('wishlist');
                const type = isWishlistPage ? 'wishlist' : 'collection';

                const res = await fetch('<%= baseUrl %>/import/discogs', {
                    method: 'POST',
                    headers: { 'Content-Type': 'application/json' },
                    body: JSON.stringify({
                        discogsUrl: fakeUrl,
                        full: false,
                        type: type
                    })
                });

                if (!res.ok) {
                    socket.off('import_finished');
                    socket.off('import_error');
                    icon.classList.remove('fa-spin');
                    btn.disabled = false;
                }
            } catch (e) {
                console.error(e);
                icon.classList.remove('fa-spin');
                btn.disabled = false;
            }
        }
    <% } %>
    </script>

    <style>
        .custom-scrollbar::-webkit-scrollbar {
            width: 4px;
        }

        .custom-scrollbar::-webkit-scrollbar-track {
            background: transparent;
        }

        .custom-scrollbar::-webkit-scrollbar-thumb {
            background: rgba(100, 100, 100, 0.2);
            border-radius: 2px;
        }

        .dark .custom-scrollbar::-webkit-scrollbar-thumb {
            background: rgba(255, 255, 255, 0.1);
        }
    </style>

    <%- include('partials/footer') %>
